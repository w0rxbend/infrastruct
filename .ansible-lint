---
profile: production
offline: true

exclude_paths:
  - .cache/

skip_list:
  # Temporary scaffold exception: baseline.yml still references local roles by
  # relative path. Remove after playbook role references use ansible/roles names.
  - role-name[path]

warn_list:
  # Keep experimental rules visible without making the current scaffold depend
  # on ansible-lint behavior that may change between workstation installs.
  - experimental

#!/usr/bin/env python3
"""Run SOPS policy validator fixture cases in disposable repo copies."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
VALIDATOR = ROOT / "scripts/validate-sops-policy"
FIXTURES = ROOT / "tests/fixtures/sops-policy"


@dataclass(frozen=True)
class FixtureCase:
    name: str
    should_pass: bool
    expected_output: str = ""


CASES = (
    FixtureCase("clean-dummy-policy", True),
    FixtureCase("example-encrypted-file", True),
    FixtureCase(
        "non-example-encrypted-file",
        False,
        "SOPS-encrypted content under the dummy age recipient",
    ),
    FixtureCase(
        "plaintext-secret-assignment",
        False,
        "plaintext-looking secret assignment for API_TOKEN",
    ),
)


def materialized_path(path: Path) -> Path:
    if path.name.endswith(".fixture"):
        return path.with_name(path.name.removesuffix(".fixture"))
    return path


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/validate-sops-policy"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(VALIDATOR, script_path)

    for source in fixture.rglob("*"):
        if not source.is_file():
            continue
        relative = materialized_path(source.relative_to(fixture))
        target = destination / relative
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)

    subprocess.run(["git", "init", "-q"], cwd=destination, check=True)
    subprocess.run(["git", "add", "."], cwd=destination, check=True)
    return script_path


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"sops-policy-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        result = subprocess.run(
            [sys.executable, str(script_path)],
            cwd=tmp_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL SOPS policy fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS SOPS policy fixture: {case.name}")

    if failures:
        print("SOPS policy validator fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("SOPS policy validator fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

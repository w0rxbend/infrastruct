#!/usr/bin/env bash
set -euo pipefail

inventory="ansible/inventories/homelab/hosts.yml"
repo_mode_file="repo-mode.yml"
inventory_validator="$(dirname "${BASH_SOURCE[0]}")/validate-inventory"
syntax_inventory="${inventory}"
tmpdir=""

cleanup() {
  if [[ -n "${tmpdir}" ]]; then
    rm -rf "${tmpdir}"
  fi
}
trap cleanup EXIT

mapfile -t playbooks < <(
  find ansible/playbooks \
    -type f \( -name '*.yml' -o -name '*.yaml' \) \
    -print | sort
)

if [[ ${#playbooks[@]} -eq 0 ]]; then
  echo "No Ansible playbooks found."
  exit 0
fi

if [[ ! -x "${inventory_validator}" ]]; then
  echo "ERROR: inventory validator is missing or not executable: ${inventory_validator}" >&2
  exit 1
fi

echo "Validating inventory contract before Ansible syntax checks."
"${inventory_validator}"

repo_mode_data="$(
  python3 - "${repo_mode_file}" <<'PY'
from __future__ import annotations

import sys
from pathlib import Path

try:
    import yaml
except ImportError:
    print(
        "ERROR: PyYAML is required for Ansible syntax mode validation.",
        file=sys.stderr,
    )
    sys.exit(1)

repo_mode_file = Path(sys.argv[1])
allowed_modes = {"discovery", "real-fleet"}

try:
    data = yaml.safe_load(repo_mode_file.read_text(encoding="utf-8"))
except FileNotFoundError:
    print(f"ERROR: repository mode file is missing: {repo_mode_file}", file=sys.stderr)
    sys.exit(1)
except yaml.YAMLError as exc:
    print(f"ERROR: repository mode YAML does not parse: {exc}", file=sys.stderr)
    sys.exit(1)

if not isinstance(data, dict):
    print("ERROR: repo-mode.yml root must be a mapping", file=sys.stderr)
    sys.exit(1)

mode = data.get("mode")
if not isinstance(mode, str) or not mode.strip():
    print("ERROR: repo-mode.yml mode must be a non-empty string", file=sys.stderr)
    sys.exit(1)
mode = mode.strip()

expected_host_count = data.get("expected_host_count")
if isinstance(expected_host_count, bool) or not isinstance(expected_host_count, int):
    print("ERROR: repo-mode.yml expected_host_count must be an integer", file=sys.stderr)
    sys.exit(1)

if mode not in allowed_modes:
    print(
        "ERROR: repo-mode.yml mode must be one of: "
        + ", ".join(sorted(allowed_modes)),
        file=sys.stderr,
    )
    sys.exit(1)

if mode == "discovery":
    if expected_host_count != 0:
        print("ERROR: discovery mode requires expected_host_count: 0", file=sys.stderr)
        sys.exit(1)
elif expected_host_count <= 0:
    print(
        f"ERROR: {mode} mode requires expected_host_count to be greater than zero",
        file=sys.stderr,
    )
    sys.exit(1)

print(mode)
print(expected_host_count)
PY
)"
readarray -t repo_mode_fields <<<"${repo_mode_data}"
repo_mode="${repo_mode_fields[0]}"
expected_host_count="${repo_mode_fields[1]}"

if ! command -v ansible-playbook >/dev/null 2>&1; then
  echo "MISSING TOOL: ansible-playbook is required for Ansible syntax validation. Install ansible-core." >&2
  exit 1
fi

if [[ "${repo_mode}" == "discovery" && "${expected_host_count}" == "0" ]]; then
  tmpdir="$(mktemp -d)"
  syntax_inventory="${tmpdir}/hosts.yml"
  if [[ -d "$(dirname "${inventory}")/group_vars" ]]; then
    ln -s "$(pwd)/$(dirname "${inventory}")/group_vars" "${tmpdir}/group_vars"
  fi
  cat >"${syntax_inventory}" <<'EOF'
---
all:
  hosts:
    discovery_syntax_host:
      ansible_connection: local
      ansible_host: 127.0.0.1
      hostname: discovery-syntax-host
      architecture: arm64
      hardware_model: syntax-validation-placeholder
      storage_type: ssd
      runtime_roles: []
      reliability_notes: Discovery-mode syntax validation placeholder.
      placement_notes: Not a real inventory host.
      public_exposure:
        exposed: false
        services: []
        notes: Discovery-mode syntax validation placeholder.
  children:
    k3s_servers:
      hosts:
        discovery_syntax_host:
    k3s_agents:
      hosts:
        discovery_syntax_host:
    docker_hosts:
      hosts:
        discovery_syntax_host:
    swarm_managers:
      hosts:
        discovery_syntax_host:
    swarm_workers:
      hosts:
        discovery_syntax_host:
    edge_nodes:
      hosts:
        discovery_syntax_host:
    arm64:
      hosts:
        discovery_syntax_host:
    armv7:
      hosts:
        discovery_syntax_host:
    pi_zero:
      hosts:
        discovery_syntax_host:
    ssd_storage:
      hosts:
        discovery_syntax_host:
    sdcard_storage:
      hosts:
        discovery_syntax_host:
    public_exposed:
      hosts:
        discovery_syntax_host:
EOF
  echo "Discovery mode with expected_host_count 0: using a synthetic local inventory for Ansible syntax checks."
fi

for playbook in "${playbooks[@]}"; do
  echo "Validating Ansible syntax: ${playbook}"
  ansible-playbook -i "${syntax_inventory}" --syntax-check "${playbook}"
done

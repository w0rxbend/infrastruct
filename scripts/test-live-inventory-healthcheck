#!/usr/bin/env python3
"""Exercise live inventory healthcheck behavior with fake Ansible tools."""

from __future__ import annotations

import os
import shutil
import stat
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
HEALTHCHECK = ROOT / "scripts/live-inventory-healthcheck"
MAKEFILE = ROOT / "Makefile"
FIXTURES = ROOT / "tests/fixtures/live-inventory-healthcheck"


@dataclass(frozen=True)
class FixtureCase:
    name: str
    should_pass: bool
    expected_output: str
    expected_exit_code: int | None = None
    install_inventory_tool: bool = True
    install_ansible_tool: bool = True
    inventory_exit_code: int = 0
    ansible_exit_code: int = 0
    ansible_output: str = "fixture-host | SUCCESS => {\"ping\": \"pong\"}"
    args: tuple[str, ...] = ()
    expected_log: tuple[str, ...] = ()
    forbidden_log: tuple[str, ...] = ()


@dataclass(frozen=True)
class RunnerCase:
    name: str
    should_pass: bool
    expected_output: str
    expected_exit_code: int | None = None
    install_runtime: bool = True
    runtime_name: str = "docker"
    runtime_exit_code: int = 0
    args: tuple[str, ...] = ()
    env: dict[str, str] | None = None
    expected_log: tuple[str, ...] = ()
    forbidden_log: tuple[str, ...] = ()


CASES = (
    FixtureCase(
        "missing-ansible-inventory",
        False,
        "MISSING TOOL: ansible-inventory",
        expected_exit_code=127,
        install_inventory_tool=False,
        expected_log=(),
    ),
    FixtureCase(
        "missing-ansible",
        False,
        "MISSING TOOL: ansible is required",
        expected_exit_code=127,
        install_ansible_tool=False,
        expected_log=(),
    ),
    FixtureCase(
        "inventory-render-failure",
        False,
        "ansible-inventory could not render inventory.yml",
        expected_exit_code=2,
        inventory_exit_code=3,
        expected_log=("ansible-inventory argv=-i inventory.yml --list",),
    ),
    FixtureCase(
        "successful-ping",
        True,
        "OK: all targeted hosts responded to Ansible ping.",
        expected_exit_code=0,
        expected_log=(
            "ansible-inventory argv=-i inventory.yml --list",
            "ansible argv=all -i inventory.yml -m ansible.builtin.ping -e ansible_become=false",
            "ansible env ANSIBLE_BECOME=false",
            "ansible env ANSIBLE_TIMEOUT=10",
        ),
        forbidden_log=("--become", " -b ", "--ask-become-pass", " -K "),
    ),
    FixtureCase(
        "unreachable-host",
        False,
        "LIVE REACHABILITY FAILURE",
        expected_exit_code=4,
        ansible_exit_code=2,
        ansible_output="fixture-host | UNREACHABLE! => {\"msg\": \"Connection timed out\"}",
        expected_log=("ansible argv=all -i inventory.yml -m ansible.builtin.ping -e ansible_become=false",),
    ),
    FixtureCase(
        "module-failure",
        False,
        "ANSIBLE EXECUTION FAILURE",
        expected_exit_code=2,
        ansible_exit_code=2,
        ansible_output="fixture-host | FAILED! => {\"msg\": \"module execution failed\"}",
        expected_log=("ansible argv=all -i inventory.yml -m ansible.builtin.ping -e ansible_become=false",),
    ),
    FixtureCase(
        "host-limit-argument",
        True,
        "ansible edge_nodes -i inventory.yml -m ansible.builtin.ping",
        expected_exit_code=0,
        args=("edge_nodes",),
        expected_log=("ansible argv=edge_nodes -i inventory.yml -m ansible.builtin.ping -e ansible_become=false",),
    ),
    FixtureCase(
        "no-become-flags",
        True,
        "OK: all targeted hosts responded to Ansible ping.",
        expected_exit_code=0,
        expected_log=(
            "ansible argv=all -i inventory.yml -m ansible.builtin.ping -e ansible_become=false",
            "ansible env ANSIBLE_BECOME=false",
        ),
        forbidden_log=("--become", " -b ", "--ask-become-pass", " -K ", "ansible_become=true"),
    ),
)


RUNNER_CASES = (
    RunnerCase(
        "runner-missing-runtime",
        False,
        "MISSING TOOL: docker or podman is required for runner-backed live inventory healthcheck.",
        expected_exit_code=127,
        install_runtime=False,
    ),
    RunnerCase(
        "runner-host-limit-no-become",
        True,
        "runner simulated live healthcheck",
        expected_exit_code=0,
        args=("edge_nodes",),
        expected_log=(
            "docker argv=build -f ",
            "docker argv=run --rm --network host",
            "-v ",
            ":/workspace:ro",
            "infrastruct-validate:local scripts/live-inventory-healthcheck edge_nodes",
            "-e ANSIBLE_TIMEOUT=10",
        ),
        forbidden_log=("--become", " -b ", "--ask-become-pass", " -K ", "ansible_become=true"),
    ),
    RunnerCase(
        "runner-ansible-limit-env",
        True,
        "runner simulated live healthcheck",
        expected_exit_code=0,
        env={"ANSIBLE_LIMIT": "k3s_servers"},
        expected_log=(
            "docker argv=run --rm --network host",
            "-e ANSIBLE_LIMIT=k3s_servers",
            "infrastruct-validate:local scripts/live-inventory-healthcheck",
        ),
        forbidden_log=("scripts/live-inventory-healthcheck k3s_servers", "--become", "ansible_become=true"),
    ),
)


def write_executable(path: Path, content: str) -> None:
    path.write_text(content, encoding="utf-8")
    path.chmod(path.stat().st_mode | stat.S_IXUSR | stat.S_IXGRP | stat.S_IXOTH)


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/live-inventory-healthcheck"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(HEALTHCHECK, script_path)
    shutil.copy2(fixture / "inventory.yml", destination / "inventory.yml")
    return script_path


def write_fake_tools(bin_dir: Path, case: FixtureCase) -> None:
    bin_dir.mkdir(parents=True)

    if case.install_inventory_tool:
        write_executable(
            bin_dir / "ansible-inventory",
            f"""#!/bin/sh
set -eu
printf 'ansible-inventory argv=%s\\n' "$*" >>"${{LIVE_HEALTHCHECK_CALL_LOG:?}}"
if [ {case.inventory_exit_code} -ne 0 ]; then
  printf 'fake inventory render failure\\n' >&2
  exit {case.inventory_exit_code}
fi
printf '%s\\n' '{{"all": {{"hosts": ["fixture-host"]}}, "_meta": {{"hostvars": {{}}}}}}'
""",
        )

    if case.install_ansible_tool:
        write_executable(
            bin_dir / "ansible",
            f"""#!/bin/sh
set -eu
printf 'ansible argv=%s\\n' "$*" >>"${{LIVE_HEALTHCHECK_CALL_LOG:?}}"
printf 'ansible env ANSIBLE_BECOME=%s\\n' "${{ANSIBLE_BECOME:-}}" >>"${{LIVE_HEALTHCHECK_CALL_LOG:?}}"
printf 'ansible env ANSIBLE_TIMEOUT=%s\\n' "${{ANSIBLE_TIMEOUT:-}}" >>"${{LIVE_HEALTHCHECK_CALL_LOG:?}}"
for arg in "$@"; do
  case "$arg" in
    --become|-b|--ask-become-pass|-K)
      printf 'fake ansible rejected privilege escalation flag: %s\\n' "$*" >&2
      exit 99
      ;;
  esac
done
cat <<'FAKE_ANSIBLE_OUTPUT'
{case.ansible_output}
FAKE_ANSIBLE_OUTPUT
exit {case.ansible_exit_code}
""",
        )


def write_fake_runtime(bin_dir: Path, case: RunnerCase) -> None:
    bin_dir.mkdir(parents=True)
    write_executable(
        bin_dir / "dirname",
        """#!/bin/sh
path="${2:-$1}"
case "$path" in
  */*) printf '%s\\n' "${path%/*}" ;;
  *) printf '.\\n' ;;
esac
""",
    )
    write_executable(
        bin_dir / "uname",
        """#!/bin/sh
printf 'Linux\\n'
""",
    )

    if not case.install_runtime:
        return

    write_executable(
        bin_dir / case.runtime_name,
        f"""#!/bin/sh
set -eu
printf '{case.runtime_name} argv=%s\\n' "$*" >>"${{LIVE_HEALTHCHECK_CALL_LOG:?}}"
if [ "$1" = "run" ]; then
  printf 'runner simulated live healthcheck\\n'
fi
exit {case.runtime_exit_code}
""",
    )


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"live-inventory-healthcheck-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        bin_dir = tmp_root / "bin"
        call_log = tmp_root / "healthcheck.log"
        write_fake_tools(bin_dir, case)

        env = os.environ.copy()
        env["PATH"] = f"{bin_dir}{os.pathsep}/bin"
        env["INVENTORY"] = "inventory.yml"
        env["LIVE_HEALTHCHECK_CALL_LOG"] = str(call_log)
        env.pop("ANSIBLE_LIMIT", None)
        env.pop("ANSIBLE_TIMEOUT", None)
        env.pop("ANSIBLE_BECOME", None)

        result = subprocess.run(
            ["/bin/bash", str(script_path), *case.args],
            cwd=tmp_root,
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        log_output = call_log.read_text(encoding="utf-8") if call_log.exists() else ""

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_exit_code is not None and result.returncode != case.expected_exit_code:
        failures.append(
            f"{case.name}: expected exit {case.expected_exit_code}, got {result.returncode}\n{output}"
        )
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    for expected in case.expected_log:
        if expected not in log_output:
            failures.append(f"{case.name}: expected fake-tool log not found: {expected!r}\n{log_output}")
    for forbidden in case.forbidden_log:
        if forbidden in log_output:
            failures.append(f"{case.name}: forbidden fake-tool log found: {forbidden!r}\n{log_output}")
    return failures


def run_runner_case(case: RunnerCase) -> list[str]:
    with tempfile.TemporaryDirectory(prefix=f"live-inventory-healthcheck-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = tmp_root / "scripts/live-inventory-healthcheck"
        script_path.parent.mkdir(parents=True)
        shutil.copy2(HEALTHCHECK, script_path)
        bin_dir = tmp_root / "bin"
        call_log = tmp_root / "runner.log"
        write_fake_runtime(bin_dir, case)

        env = os.environ.copy()
        env["PATH"] = str(bin_dir)
        env["LIVE_HEALTHCHECK_CALL_LOG"] = str(call_log)
        env.pop("ANSIBLE_LIMIT", None)
        env.pop("ANSIBLE_TIMEOUT", None)
        env.pop("ANSIBLE_BECOME", None)
        env.pop("VALIDATION_RUNNER_ENGINE", None)
        env.pop("VALIDATION_RUNNER_IMAGE", None)
        env.pop("VALIDATION_RUNNER_SKIP_BUILD", None)
        if case.env:
            env.update(case.env)

        result = subprocess.run(
            ["/bin/bash", str(script_path), "--runner", *case.args],
            cwd=tmp_root,
            env=env,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )
        log_output = call_log.read_text(encoding="utf-8") if call_log.exists() else ""

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_exit_code is not None and result.returncode != case.expected_exit_code:
        failures.append(
            f"{case.name}: expected exit {case.expected_exit_code}, got {result.returncode}\n{output}"
        )
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    for expected in case.expected_log:
        if expected not in log_output:
            failures.append(f"{case.name}: expected fake-runtime log not found: {expected!r}\n{log_output}")
    for forbidden in case.forbidden_log:
        if forbidden in log_output:
            failures.append(f"{case.name}: forbidden fake-runtime log found: {forbidden!r}\n{log_output}")
    return failures


def validate_make_targets() -> list[str]:
    text = MAKEFILE.read_text(encoding="utf-8")
    failures: list[str] = []
    if "live-inventory-healthcheck-runner:" not in text:
        failures.append("Makefile: missing live-inventory-healthcheck-runner target")
    if "\n\t@scripts/live-inventory-healthcheck --runner" not in text:
        failures.append("Makefile: runner target does not invoke scripts/live-inventory-healthcheck --runner")

    target_deps: dict[str, set[str]] = {}
    for line in text.splitlines():
        if not line or line.startswith("\t") or line.startswith("."):
            continue
        if ":" not in line:
            continue
        target, deps = line.split(":", 1)
        target_deps[target.strip()] = set(deps.split())

    for target in ("validate", "validate-local-contracts", "validate-full"):
        if "live-inventory-healthcheck-runner" in target_deps.get(target, set()):
            failures.append(f"Makefile: {target} must not depend on live-inventory-healthcheck-runner")
        if "live-inventory-healthcheck" in target_deps.get(target, set()):
            failures.append(f"Makefile: {target} must not depend on live-inventory-healthcheck")
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL live inventory healthcheck fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS live inventory healthcheck fixture: {case.name}")

    for case in RUNNER_CASES:
        case_failures = run_runner_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL live inventory healthcheck runner fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS live inventory healthcheck runner fixture: {case.name}")

    make_failures = validate_make_targets()
    if make_failures:
        failures.extend(make_failures)
        print("FAIL live inventory healthcheck Makefile target checks", file=sys.stderr)
    else:
        print("PASS live inventory healthcheck Makefile target checks")

    if failures:
        print("Live inventory healthcheck fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Live inventory healthcheck fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

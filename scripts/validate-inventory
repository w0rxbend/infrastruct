#!/usr/bin/env python3
"""Validate the production Ansible inventory contract."""

from __future__ import annotations

import ipaddress
import sys
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:
    print("ERROR: PyYAML is required for inventory validation.", file=sys.stderr)
    sys.exit(1)


ROOT = Path(__file__).resolve().parents[1]
INVENTORY = ROOT / "ansible/inventories/homelab/hosts.yml"
REPO_MODE = ROOT / "repo-mode.yml"
GROUP_CONTRACT = ROOT / "ansible/inventories/homelab/group_contract.yml"

BASE_REQUIRED_HOST_FIELDS = {
    "hostname",
    "ansible_host",
    "reliability_notes",
    "placement_notes",
}

ALLOWED_REPO_MODES = {
    "discovery",
    "real-fleet",
}

PLACEHOLDER_WORDS = (
    "example",
    "placeholder",
    "replace-before-use",
    "changeme",
    "change-me",
    "todo",
)

RFC5737_NETWORKS = (
    ipaddress.ip_network("192.0.2.0/24"),
    ipaddress.ip_network("198.51.100.0/24"),
    ipaddress.ip_network("203.0.113.0/24"),
)


def fail(errors: list[str], message: str) -> None:
    errors.append(message)


def string_list(value: Any) -> list[str]:
    if not isinstance(value, list):
        return []
    return [item for item in value if isinstance(item, str) and item.strip()]


def string_map(value: Any) -> dict[str, str]:
    if not isinstance(value, dict):
        return {}
    return {
        key: item
        for key, item in value.items()
        if isinstance(key, str) and key.strip() and isinstance(item, str) and item.strip()
    }


def host_var_name(rule: Any, default: str) -> str:
    if not isinstance(rule, dict):
        return default
    value = rule.get("host_var")
    if isinstance(value, str) and value.strip():
        return value.strip()
    return default


def required_host_fields_from_contract(
    runtime_rule: Any,
    architecture_rule: Any,
    storage_rule: Any,
    pi_zero_rule: Any,
    public_exposure_rule: Any,
) -> set[str]:
    return BASE_REQUIRED_HOST_FIELDS | {
        host_var_name(runtime_rule, "runtime_roles"),
        host_var_name(architecture_rule, "architecture"),
        host_var_name(storage_rule, "storage_type"),
        host_var_name(pi_zero_rule, "hardware_model"),
        host_var_name(public_exposure_rule, "public_exposure"),
    }


def load_group_contract(errors: list[str]) -> dict[str, Any]:
    try:
        data = yaml.safe_load(GROUP_CONTRACT.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(errors, f"group contract file is missing: {GROUP_CONTRACT.relative_to(ROOT)}")
        return {}
    except yaml.YAMLError as exc:
        fail(errors, f"group contract YAML does not parse: {exc}")
        return {}

    if not isinstance(data, dict):
        fail(errors, "group contract root must be a mapping")
        return {}

    required_groups = data.get("required_groups")
    if string_list(required_groups) != required_groups:
        fail(errors, "group contract required_groups must be a list of non-empty strings")

    placement_rules = data.get("placement_rules")
    if not isinstance(placement_rules, dict):
        fail(errors, "group contract placement_rules must be a mapping")
        placement_rules = {}

    for rule_name in ("runtime_roles", "architecture", "storage"):
        rule = placement_rules.get(rule_name)
        if not isinstance(rule, dict):
            fail(errors, f"group contract placement_rules.{rule_name} must be a mapping")
            continue
        if not isinstance(rule.get("host_var"), str) or not rule["host_var"].strip():
            fail(errors, f"group contract placement_rules.{rule_name}.host_var must be a non-empty string")
        if not string_map(rule.get("groups")):
            fail(errors, f"group contract placement_rules.{rule_name}.groups must map values to groups")

    for rule_name in ("raspberry_pi_zero", "public_exposure"):
        rule = placement_rules.get(rule_name)
        if not isinstance(rule, dict):
            fail(errors, f"group contract placement_rules.{rule_name} must be a mapping")
            continue
        if not isinstance(rule.get("host_var"), str) or not rule["host_var"].strip():
            fail(errors, f"group contract placement_rules.{rule_name}.host_var must be a non-empty string")
        if not isinstance(rule.get("group"), str) or not rule["group"].strip():
            fail(errors, f"group contract placement_rules.{rule_name}.group must be a non-empty string")

    pi_zero_rule = placement_rules.get("raspberry_pi_zero")
    if isinstance(pi_zero_rule, dict) and (
        not isinstance(pi_zero_rule.get("substring"), str) or not pi_zero_rule["substring"].strip()
    ):
        fail(errors, "group contract placement_rules.raspberry_pi_zero.substring must be a non-empty string")

    public_exposure_rule = placement_rules.get("public_exposure")
    if isinstance(public_exposure_rule, dict) and (
        not isinstance(public_exposure_rule.get("exposed_field"), str)
        or not public_exposure_rule["exposed_field"].strip()
    ):
        fail(errors, "group contract placement_rules.public_exposure.exposed_field must be a non-empty string")

    required_group_names = set(string_list(required_groups))
    if required_group_names and isinstance(placement_rules, dict):
        for rule_name, rule in sorted(placement_rules.items()):
            if not isinstance(rule, dict):
                continue

            group = rule.get("group")
            if isinstance(group, str) and group.strip() and group not in required_group_names:
                fail(
                    errors,
                    f"group contract placement_rules.{rule_name}.group references "
                    f"group {group!r} not listed in required_groups",
                )

            groups = rule.get("groups")
            if not isinstance(groups, dict):
                continue
            for value, group_name in sorted(groups.items(), key=lambda item: str(item[0])):
                if not isinstance(group_name, str) or not group_name.strip():
                    continue
                if group_name not in required_group_names:
                    fail(
                        errors,
                        f"group contract placement_rules.{rule_name}.groups.{value} references "
                        f"group {group_name!r} not listed in required_groups",
                    )

    return data


def load_inventory(errors: list[str]) -> dict[str, Any]:
    try:
        data = yaml.safe_load(INVENTORY.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(errors, f"inventory file is missing: {INVENTORY.relative_to(ROOT)}")
        return {}
    except yaml.YAMLError as exc:
        fail(errors, f"inventory YAML does not parse: {exc}")
        return {}
    if not isinstance(data, dict):
        fail(errors, "inventory root must be a mapping")
        return {}
    return data


def load_repo_mode(errors: list[str]) -> tuple[str, int]:
    try:
        data = yaml.safe_load(REPO_MODE.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(errors, f"repository mode file is missing: {REPO_MODE.relative_to(ROOT)}")
        return "", -1
    except yaml.YAMLError as exc:
        fail(errors, f"repository mode YAML does not parse: {exc}")
        return "", -1

    if not isinstance(data, dict):
        fail(errors, "repo-mode.yml root must be a mapping")
        return "", -1

    mode = data.get("mode")
    if not isinstance(mode, str) or not mode.strip():
        fail(errors, "repo-mode.yml mode must be a non-empty string")
        mode = ""
    else:
        mode = mode.strip()

    expected_host_count = data.get("expected_host_count")
    if isinstance(expected_host_count, bool) or not isinstance(expected_host_count, int):
        fail(errors, "repo-mode.yml expected_host_count must be an integer")
        expected_host_count = -1

    return mode, expected_host_count


def validate_repository_mode(mode: str, expected_host_count: int, host_count: int, errors: list[str]) -> None:
    if not mode or expected_host_count < 0:
        return

    if mode not in ALLOWED_REPO_MODES:
        fail(errors, f"repo-mode.yml mode must be one of: {', '.join(sorted(ALLOWED_REPO_MODES))}")
        return

    if mode == "discovery":
        if expected_host_count != 0:
            fail(errors, "discovery mode requires expected_host_count: 0")
        if host_count != 0:
            fail(errors, "discovery mode requires an empty production inventory; switch repo-mode.yml before adding real hosts")
        return

    if expected_host_count <= 0:
        fail(errors, f"{mode} mode requires expected_host_count to be greater than zero")
        return

    if host_count != expected_host_count:
        fail(
            errors,
            f"{mode} mode expected {expected_host_count} production hosts, found {host_count}",
        )


def group_hosts(group: dict[str, Any]) -> set[str]:
    hosts = group.get("hosts") or {}
    if not isinstance(hosts, dict):
        return set()
    return set(hosts)


def contains_placeholder(value: Any) -> bool:
    if isinstance(value, str):
        lowered = value.lower()
        return any(word in lowered for word in PLACEHOLDER_WORDS)
    if isinstance(value, dict):
        return any(contains_placeholder(item) for item in value.values())
    if isinstance(value, list):
        return any(contains_placeholder(item) for item in value)
    return False


def is_rfc5737_address(value: Any) -> bool:
    if not isinstance(value, str):
        return False
    try:
        address = ipaddress.ip_address(value)
    except ValueError:
        return False
    return any(address in network for network in RFC5737_NETWORKS)


def validate_public_exposure(
    hostname: str,
    host_vars: dict[str, Any],
    in_group: bool,
    group_name: str,
    host_var_name: str,
    exposed_field: str,
    errors: list[str],
) -> None:
    exposure = host_vars.get(host_var_name)
    if not isinstance(exposure, dict):
        fail(errors, f"{hostname}: {host_var_name} must be a mapping")
        return

    exposed = exposure.get(exposed_field)
    if not isinstance(exposed, bool):
        fail(errors, f"{hostname}: {host_var_name}.{exposed_field} must be true or false")
        return

    if exposed != in_group:
        fail(
            errors,
            f"{hostname}: {host_var_name}.{exposed_field}={exposed} does not match {group_name} group membership",
        )

    services = exposure.get("services")
    if services is None:
        fail(errors, f"{hostname}: {host_var_name}.services is required")
    elif not isinstance(services, list):
        fail(errors, f"{hostname}: {host_var_name}.services must be a list")

    notes = exposure.get("notes")
    if not isinstance(notes, str) or not notes.strip():
        fail(errors, f"{hostname}: {host_var_name}.notes must be a non-empty string")

    if exposed:
        if not services:
            fail(errors, f"{hostname}: exposed hosts must declare at least one public service")
            return
        for index, service in enumerate(services or [], start=1):
            if not isinstance(service, dict):
                fail(errors, f"{hostname}: {host_var_name}.services[{index}] must be a mapping")
                continue
            for field in ("name", "protocol", "public_port", "owner", "internal_target"):
                if field not in service or service[field] in ("", None):
                    fail(errors, f"{hostname}: public service {index} is missing {field}")


def main() -> int:
    errors: list[str] = []
    mode, expected_host_count = load_repo_mode(errors)
    group_contract = load_group_contract(errors)
    placement_rules = group_contract.get("placement_rules") or {}
    runtime_rule = placement_rules.get("runtime_roles") if isinstance(placement_rules, dict) else {}
    architecture_rule = placement_rules.get("architecture") if isinstance(placement_rules, dict) else {}
    storage_rule = placement_rules.get("storage") if isinstance(placement_rules, dict) else {}
    pi_zero_rule = placement_rules.get("raspberry_pi_zero") if isinstance(placement_rules, dict) else {}
    public_exposure_rule = placement_rules.get("public_exposure") if isinstance(placement_rules, dict) else {}
    if not isinstance(runtime_rule, dict):
        runtime_rule = {}
    if not isinstance(architecture_rule, dict):
        architecture_rule = {}
    if not isinstance(storage_rule, dict):
        storage_rule = {}
    if not isinstance(pi_zero_rule, dict):
        pi_zero_rule = {}
    if not isinstance(public_exposure_rule, dict):
        public_exposure_rule = {}

    required_groups = string_list(group_contract.get("required_groups"))
    role_groups = string_map(runtime_rule.get("groups"))
    arch_groups = string_map(architecture_rule.get("groups"))
    storage_groups = string_map(storage_rule.get("groups"))
    runtime_host_var = host_var_name(runtime_rule, "runtime_roles")
    architecture_host_var = host_var_name(architecture_rule, "architecture")
    storage_host_var = host_var_name(storage_rule, "storage_type")
    pi_zero_host_var = host_var_name(pi_zero_rule, "hardware_model")
    pi_zero_group = pi_zero_rule.get("group", "pi_zero")
    pi_zero_substring = pi_zero_rule.get("substring", "zero")
    public_exposure_host_var = host_var_name(public_exposure_rule, "public_exposure")
    public_exposure_group = public_exposure_rule.get("group", "public_exposed")
    public_exposure_exposed_field = public_exposure_rule.get("exposed_field", "exposed")

    inventory = load_inventory(errors)
    all_group = inventory.get("all") if isinstance(inventory, dict) else None
    if not isinstance(all_group, dict):
        fail(errors, "inventory must contain an all group mapping")
        all_group = {}

    hosts = all_group.get("hosts") or {}
    if not isinstance(hosts, dict):
        fail(errors, "all.hosts must be a mapping")
        hosts = {}

    validate_repository_mode(mode, expected_host_count, len(hosts), errors)

    children = all_group.get("children") or {}
    if not isinstance(children, dict):
        fail(errors, "all.children must be a mapping")
        children = {}

    for group_name in sorted(required_groups):
        group = children.get(group_name)
        if not isinstance(group, dict):
            fail(errors, f"required group is missing or invalid: {group_name}")
            continue
        if not isinstance(group.get("hosts", {}), dict):
            fail(errors, f"{group_name}.hosts must be a mapping")

    memberships = {
        group_name: group_hosts(group)
        for group_name, group in children.items()
        if isinstance(group, dict)
    }

    declared_hosts = set(hosts)
    for group_name, members in memberships.items():
        unknown = members - declared_hosts
        for hostname in sorted(unknown):
            fail(errors, f"{group_name}: group references undeclared host {hostname}")

    for hostname, host_vars in sorted(hosts.items()):
        if not isinstance(host_vars, dict):
            fail(errors, f"{hostname}: host vars must be a mapping")
            continue

        if contains_placeholder(hostname) or contains_placeholder(host_vars):
            fail(errors, f"{hostname}: placeholder or replace-before-use value is not allowed in production inventory")

        required_host_fields = required_host_fields_from_contract(
            runtime_rule,
            architecture_rule,
            storage_rule,
            pi_zero_rule,
            public_exposure_rule,
        )
        missing = sorted(field for field in required_host_fields if field not in host_vars)
        if missing:
            fail(errors, f"{hostname}: missing required fields: {', '.join(missing)}")
            continue

        if host_vars.get("hostname") != hostname:
            fail(errors, f"{hostname}: hostname field must match inventory hostname")

        if is_rfc5737_address(host_vars.get("ansible_host")):
            fail(errors, f"{hostname}: ansible_host uses an RFC 5737 documentation address")

        roles = host_vars.get(runtime_host_var)
        if not isinstance(roles, list) or not roles:
            fail(errors, f"{hostname}: {runtime_host_var} must be a non-empty list")
            roles = []

        for role in roles:
            expected_group = role_groups.get(role)
            if expected_group is None:
                fail(errors, f"{hostname}: unknown runtime role {role!r}")
                continue
            if hostname not in memberships.get(expected_group, set()):
                fail(errors, f"{hostname}: runtime role {role!r} requires membership in {expected_group}")

        for role, group_name in role_groups.items():
            if hostname in memberships.get(group_name, set()) and role not in roles:
                fail(errors, f"{hostname}: membership in {group_name} requires runtime role {role!r}")

        architecture = host_vars.get(architecture_host_var)
        expected_arch_group = arch_groups.get(architecture)
        if expected_arch_group is None:
            fail(errors, f"{hostname}: {architecture_host_var} must be one of {', '.join(sorted(arch_groups))}")
        elif hostname not in memberships.get(expected_arch_group, set()):
            fail(errors, f"{hostname}: {architecture_host_var} {architecture!r} requires membership in {expected_arch_group}")

        for group_name in arch_groups.values():
            if hostname in memberships.get(group_name, set()) and group_name != expected_arch_group:
                fail(errors, f"{hostname}: membership in {group_name} does not match {architecture_host_var} {architecture!r}")

        storage_type = host_vars.get(storage_host_var)
        expected_storage_group = storage_groups.get(storage_type)
        if expected_storage_group is None:
            fail(errors, f"{hostname}: {storage_host_var} must be one of {', '.join(sorted(storage_groups))}")
        elif hostname not in memberships.get(expected_storage_group, set()):
            fail(errors, f"{hostname}: {storage_host_var} {storage_type!r} requires membership in {expected_storage_group}")

        for group_name in storage_groups.values():
            if hostname in memberships.get(group_name, set()) and group_name != expected_storage_group:
                fail(errors, f"{hostname}: membership in {group_name} does not match {storage_host_var} {storage_type!r}")

        hardware_model = str(host_vars.get(pi_zero_host_var, "")).lower()
        pi_zero_match = str(pi_zero_substring).lower() in hardware_model
        if pi_zero_match and hostname not in memberships.get(str(pi_zero_group), set()):
            fail(errors, f"{hostname}: Raspberry Pi Zero-class hosts must be in {pi_zero_group}")
        if hostname in memberships.get(str(pi_zero_group), set()) and not pi_zero_match:
            fail(errors, f"{hostname}: {pi_zero_group} membership must match {pi_zero_host_var}")

        validate_public_exposure(
            hostname,
            host_vars,
            hostname in memberships.get(str(public_exposure_group), set()),
            str(public_exposure_group),
            str(public_exposure_host_var),
            str(public_exposure_exposed_field),
            errors,
        )

    if errors:
        print("Inventory validation failed:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1

    print(f"Inventory validation passed: {INVENTORY.relative_to(ROOT)}")
    return 0


if __name__ == "__main__":
    sys.exit(main())

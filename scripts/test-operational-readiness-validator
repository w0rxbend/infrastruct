        "real-secret-overall-reproduced-private-identity-backup-recovery-not-reproduced",
        False,
        "unreproduced gate(s): private identity backup recovery",
    ),
)


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/validate-operational-readiness"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(VALIDATOR, script_path)

    default_fixture = FIXTURES / "reproduced-evidence"
    for relative_path in (
        Path("docs/live-inventory-evidence.md"),
        Path("docs/sops-workflow-proof.md"),
        Path("ansible/playbooks/baseline.yml"),
        Path("ansible/roles/common/tasks/main.yml"),
    ):
        target = destination / relative_path
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(default_fixture / relative_path, target)

    public_discovery_target = destination / "docs/public-exposure-discovery.md"
    public_discovery_target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(ROOT / "docs/public-exposure-discovery.md", public_discovery_target)

    for source in fixture.rglob("*"):
        if not source.is_file():
            continue
        target = destination / source.relative_to(fixture)
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)

    return script_path


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"operational-readiness-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        result = subprocess.run(
            [sys.executable, str(script_path)],
            cwd=tmp_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL operational readiness fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS operational readiness fixture: {case.name}")

    if failures:
        print("Operational readiness validator fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Operational readiness validator fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

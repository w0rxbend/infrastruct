#!/usr/bin/env python3
"""Validate public exposure records across inventory and documentation."""

from __future__ import annotations

import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:
    print("ERROR: PyYAML is required for public exposure documentation validation.", file=sys.stderr)
    sys.exit(1)


ROOT = Path(__file__).resolve().parents[1]
INVENTORY = ROOT / "ansible/inventories/homelab/hosts.yml"
PUBLIC_EXPOSURE_DOC = ROOT / "docs/public-exposure.md"
SERVICES_DOC = ROOT / "docs/services.md"

NO_PRODUCTION_ROUTES_STATEMENT = (
    "No production public routes or ports have been declared in this repository yet."
)

NONE_VALUES = {"", "none", "n/a", "na", "not applicable", "not declared", "undeclared", "no", "false"}
PLACEHOLDER_VALUES = {"unknown", "tbd", "todo", "pending", "unset", "planned"}
INACTIVE_EXPOSURE_STATES = {"planned", "non production", "non-production"}
ACTIVE_EXPOSURE_STATES = {"", "active", "production"}
DOCUMENTED_EXPOSURE_STATES = {"active", "production", "planned", "non production", "non-production"}

INVENTORY_FIELD_ALIASES = {
    "route_identifier": (
        "route_id",
        "route_identifier",
        "id",
        "name",
        "service_name",
        "domain",
        "fqdn",
        "public_host",
    ),
    "public_host_or_port": (
        "public_host",
        "public_port",
        "public_endpoint",
        "domain",
        "fqdn",
        "port",
    ),
    "runtime_owner": ("runtime_owner", "runtime", "service_owner"),
    "protocol": ("protocol", "public_protocol"),
    "proxy_owner": ("proxy_owner", "proxy", "proxy_or_direct_port_routing", "routing_owner", "owner"),
    "target": (
        "target",
        "internal_target",
        "service_target",
        "upstream",
    ),
    "target_host_or_cluster": (
        "target_host_or_cluster",
        "host_or_cluster",
        "host_or_cluster_placement",
        "target_host",
        "target_cluster",
        "cluster",
        "placement",
    ),
    "firewall_intent": ("firewall_intent",),
    "secret_dependency": ("secret_dependency", "secret_source", "secret"),
    "review_notes": ("review_notes", "notes"),
}

PUBLIC_DOC_FIELD_ALIASES = {
    "route_identifier": ("route identifier", "route id", "service name"),
    "public_host_or_port": (
        "public host",
        "public port",
        "public host or port",
        "public endpoint",
        "public exposure",
    ),
    "runtime_owner": ("runtime owner", "runtime"),
    "protocol": ("protocol", "public protocol"),
    "proxy_owner": ("proxy owner", "proxy or direct-port routing", "routing owner"),
    "target": ("target", "internal target", "service target", "upstream"),
    "target_host_or_cluster": ("target host or cluster", "host or cluster", "host or cluster placement"),
    "firewall_intent": ("firewall intent",),
    "secret_dependency": ("secret dependency", "secret source"),
    "review_notes": ("review notes",),
    "exposure_state": ("exposure state", "state"),
}

SERVICE_DOC_FIELD_ALIASES = {
    "route_identifier": ("route identifier", "route id", "service name"),
    "public_host_or_port": (
        "public host",
        "public port",
        "public host or port",
        "public exposure",
        "public endpoint",
    ),
    "runtime_owner": ("runtime owner", "runtime"),
    "protocol": ("protocol", "public protocol"),
    "proxy_owner": ("proxy owner", "proxy or direct-port routing", "routing owner"),
    "target": ("target", "internal target", "service target", "upstream"),
    "target_host_or_cluster": ("target host or cluster", "host or cluster placement", "host or cluster"),
    "firewall_intent": ("firewall intent",),
    "secret_dependency": ("secret dependency", "secret source"),
    "review_notes": ("review notes", "maintenance notes"),
    "exposure_state": ("exposure state", "state"),
}

INVENTORY_FIELD_ALIASES["exposure_state"] = ("exposure_state", "state")

COMPLETE_RECORD_FIELDS = (
    "route_identifier",
    "public_host_or_port",
    "protocol",
    "runtime_owner",
    "proxy_owner",
    "target_host_or_cluster",
    "target",
    "firewall_intent",
    "secret_dependency",
    "review_notes",
)

FRIENDLY_FIELD_NAMES = {
    "route_identifier": "route identifier",
    "public_host_or_port": "public host or port",
    "runtime_owner": "runtime owner",
    "protocol": "protocol",
    "proxy_owner": "proxy owner",
    "target_host_or_cluster": "target host or cluster",
    "target": "target",
    "firewall_intent": "firewall intent",
    "secret_dependency": "secret dependency",
    "review_notes": "review notes",
}

COMPARABLE_RECORD_FIELDS = (
    "route_identifier",
    "runtime_owner",
    "proxy_owner",
    "public_host_or_port",
    "protocol",
    "target_host_or_cluster",
    "target",
    "firewall_intent",
    "secret_dependency",
    "review_notes",
)

CANONICAL_FIELD_NAMES = {
    "route_identifier": "route identifier",
    "runtime_owner": "runtime",
    "proxy_owner": "proxy owner",
    "public_host_or_port": "public host or port",
    "protocol": "protocol",
    "target_host_or_cluster": "target host or cluster",
    "target": "target",
    "firewall_intent": "firewall intent",
    "secret_dependency": "secret dependency",
    "review_notes": "review notes",
}

OPTIONAL_NONE_FIELDS = {"secret_dependency"}


@dataclass(frozen=True)
class RouteRecord:
    source: str
    location: str
    fields: dict[str, str]

    @property
    def route_identifier(self) -> str | None:
        return self.fields.get("route_identifier")


def fail(errors: list[str], message: str) -> None:
    errors.append(message)


def load_yaml(path: Path, errors: list[str]) -> dict[str, Any]:
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        fail(errors, f"required file is missing: {path.relative_to(ROOT)}")
        return {}
    except yaml.YAMLError as exc:
        fail(errors, f"{path.relative_to(ROOT)} does not parse as YAML: {exc}")
        return {}

    if data is None:
        return {}
    if not isinstance(data, dict):
        fail(errors, f"{path.relative_to(ROOT)} root must be a mapping")
        return {}
    return data


def read_text(path: Path, errors: list[str]) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except FileNotFoundError:
        fail(errors, f"required file is missing: {path.relative_to(ROOT)}")
        return ""


def public_group_hosts(children: dict[str, Any], errors: list[str]) -> set[str]:
    public_group = children.get("public_exposed", {})
    if public_group is None:
        return set()
    if not isinstance(public_group, dict):
        fail(errors, "public_exposed group must be a mapping")
        return set()

    hosts = public_group.get("hosts") or {}
    if not isinstance(hosts, dict):
        fail(errors, "public_exposed.hosts must be a mapping")
        return set()
    return set(hosts)


def normalize_key(value: str) -> str:
    value = re.sub(r"<[^>]+>", "", value)
    value = value.replace("`", "")
    value = value.replace("-", " ")
    value = value.replace("_", " ")
    return re.sub(r"\s+", " ", value.strip().lower())


def normalize_value(value: Any) -> str:
    if value is None:
        return ""
    if isinstance(value, bool):
        return str(value).lower()
    if isinstance(value, int):
        return str(value)
    if not isinstance(value, str):
        return ""
    value = value.strip()
    if value.startswith("`") and value.endswith("`") and len(value) >= 2:
        value = value[1:-1].strip()
    return re.sub(r"\s+", " ", value)


def canonical_value(value: Any, *, allow_none: bool = False) -> str:
    normalized = normalize_value(value)
    if normalize_key(normalized) in NONE_VALUES:
        return "none" if allow_none and normalized else ""
    return normalized


def has_value(value: Any, *, allow_none: bool = False) -> bool:
    normalized = canonical_value(value, allow_none=allow_none)
    if not normalized:
        return False
    return allow_none or normalize_key(normalized) not in NONE_VALUES


def has_complete_active_value(value: Any, *, allow_none: bool = False) -> bool:
    if not has_value(value, allow_none=allow_none):
        return False
    return normalize_key(canonical_value(value, allow_none=allow_none)) not in PLACEHOLDER_VALUES


def exposure_state(fields: dict[str, Any]) -> str:
    return normalize_key(canonical_value(fields.get("exposure_state")))


def is_inactive_exposure_record(fields: dict[str, Any]) -> bool:
    return exposure_state(fields) in INACTIVE_EXPOSURE_STATES


def validate_exposure_state(record: RouteRecord, errors: list[str]) -> None:
    state = exposure_state(record.fields)
    if state and state not in DOCUMENTED_EXPOSURE_STATES:
        fail(
            errors,
            f"{record.source} route record at {record.location} has invalid exposure state "
            f"{record.fields.get('exposure_state')!r}; use active, production, planned, "
            "or non-production",
        )


def canonical_field(fields: dict[str, Any], aliases: tuple[str, ...], *, allow_none: bool = False) -> str:
    for alias in aliases:
        value = fields.get(alias)
        if has_value(value, allow_none=allow_none):
            return canonical_value(value, allow_none=allow_none)
    return ""


def canonical_fields(raw_fields: dict[str, Any], aliases_by_field: dict[str, tuple[str, ...]]) -> dict[str, str]:
    normalized = {normalize_key(str(key)): value for key, value in raw_fields.items()}
    fields: dict[str, str] = {}
    for canonical, aliases in aliases_by_field.items():
        value = canonical_field(
            normalized,
            tuple(normalize_key(alias) for alias in aliases),
            allow_none=True,
        )
        if value:
            fields[canonical] = value
    return fields


def comparable_fields(record: RouteRecord) -> dict[str, str]:
    comparable: dict[str, str] = {}
    for field in COMPARABLE_RECORD_FIELDS:
        comparable[field] = canonical_value(
            record.fields.get(field),
            allow_none=field in OPTIONAL_NONE_FIELDS,
        )
    return comparable


def require_complete_record(record: RouteRecord, errors: list[str]) -> None:
    validate_exposure_state(record, errors)
    if is_inactive_exposure_record(record.fields):
        missing = [
            FRIENDLY_FIELD_NAMES[field]
            for field in COMPLETE_RECORD_FIELDS
            if not has_value(record.fields.get(field), allow_none=True)
        ]
        for field in ("route_identifier", "target_host_or_cluster"):
            if not has_complete_active_value(record.fields.get(field)):
                fail(
                    errors,
                    f"{record.source} route record at {record.location} has placeholder "
                    f"{FRIENDLY_FIELD_NAMES[field]} {record.fields.get(field)!r}; planned "
                    "and non-production public exposure drafts must use a stable route "
                    "identifier and meaningful placement target",
                )
    else:
        missing = [
            FRIENDLY_FIELD_NAMES[field]
            for field in COMPLETE_RECORD_FIELDS
            if not has_complete_active_value(
                record.fields.get(field), allow_none=field in OPTIONAL_NONE_FIELDS
            )
        ]
    if missing:
        fail(
            errors,
            f"{record.source} route record at {record.location} is missing required fields: "
            f"{', '.join(missing)}",
        )


def inventory_route_records(hosts: dict[str, Any], public_hosts: set[str], errors: list[str]) -> list[RouteRecord]:
    records: list[RouteRecord] = []

    for host in sorted(public_hosts - set(hosts)):
        fail(errors, f"public_exposed group references undeclared host {host}")

    for host, host_vars in sorted(hosts.items()):
        if not isinstance(host_vars, dict):
            continue

        exposure = host_vars.get("public_exposure")
        if exposure is None:
            if host in public_hosts:
                fail(errors, f"{host}: public_exposure is required for public_exposed hosts")
            continue
        if not isinstance(exposure, dict):
            fail(errors, f"{host}: public_exposure must be a mapping")
            continue

        services = exposure.get("services", [])
        if services is None:
            services = []
        elif not isinstance(services, list):
            fail(errors, f"{host}: public_exposure.services must be a list")
            services = []

        exposed = exposure.get("exposed") is True
        has_route_metadata = bool(services)
        if host not in public_hosts and not exposed and not has_route_metadata:
            continue

        if not services:
            fail(errors, f"{host}: public exposure is declared but no services are listed")
            continue

        for index, service in enumerate(services, start=1):
            location = f"{host}: public_exposure.services[{index}]"
            if not isinstance(service, dict):
                fail(errors, f"{location} must be a mapping")
                continue

            fields = canonical_fields(service, INVENTORY_FIELD_ALIASES)
            fields.setdefault("target_host_or_cluster", host)
            record = RouteRecord(source="inventory", location=location, fields=fields)
            require_complete_record(record, errors)
            if is_inactive_exposure_record(fields):
                continue
            if not record.route_identifier:
                fail(errors, f"{location} must include a route identifier")
                continue
            records.append(record)

    return records


def strip_inline_code(value: str) -> str:
    value = value.strip()
    if value.startswith("`") and value.endswith("`") and len(value) >= 2:
        return value[1:-1].strip()
    return value


def split_markdown_table_row(line: str) -> list[str] | None:
    stripped = line.strip()
    if not stripped.startswith("|") or not stripped.endswith("|"):
        return None
    cells = [strip_inline_code(cell.strip()) for cell in stripped.strip("|").split("|")]
    if len(cells) < 2:
        return None
    return cells


def is_markdown_table_separator(cells: list[str]) -> bool:
    return bool(cells) and all(re.fullmatch(r":?-{3,}:?", cell.strip()) for cell in cells)


def heading_text(line: str) -> str | None:
    match = re.match(r"^(#{2,6})\s+(.+?)\s*$", line)
    if match is None:
        return None
    return match.group(2).strip()


def markdown_field_tables(
    text: str,
    *,
    start_heading: str,
    source: str,
    errors: list[str],
) -> list[tuple[str, dict[str, str]]]:
    records: list[tuple[str, dict[str, str]]] = []
    current_heading: str | None = None
    current_fields: dict[str, str] = {}
    in_fence = False
    in_scope = False

    def flush() -> None:
        nonlocal current_heading, current_fields
        if current_heading is not None and current_fields:
            records.append((current_heading, current_fields))
        current_heading = None
        current_fields = {}

    for line in text.splitlines():
        if line.strip().startswith("```"):
            in_fence = not in_fence
            continue
        if in_fence:
            continue

        heading = heading_text(line)
        if heading is not None:
            if normalize_key(heading) == normalize_key(start_heading):
                in_scope = True
                flush()
                continue
            if in_scope and line.startswith("## "):
                flush()
                break
            if in_scope:
                flush()
                current_heading = heading
            continue

        if not in_scope or current_heading is None:
            continue

        stripped = line.strip()
        cells = split_markdown_table_row(line)
        if cells is None:
            if stripped and "|" in stripped:
                fail(
                    errors,
                    f"{source} record at ### {current_heading} contains malformed Markdown "
                    f"table row: {stripped!r}",
                )
            continue
        if is_markdown_table_separator(cells):
            continue
        if len(cells) != 2:
            fail(
                errors,
                f"{source} record at ### {current_heading} contains malformed Markdown "
                f"table row with {len(cells)} cells; expected 2: {stripped!r}",
            )
            continue
        if normalize_key(cells[0]) == "field" and normalize_key(cells[1]) == "value":
            continue
        normalized_field = normalize_key(cells[0])
        if normalized_field in {normalize_key(field) for field in current_fields}:
            fail(
                errors,
                f"{source} record at ### {current_heading} contains duplicate Markdown "
                f"field {cells[0]!r}",
            )
            continue
        current_fields[cells[0]] = cells[1]

    flush()
    return records


def public_doc_route_records(doc: str, errors: list[str]) -> list[RouteRecord]:
    records: list[RouteRecord] = []
    for heading, raw_fields in markdown_field_tables(
        doc,
        start_heading="Current Public Exposure",
        source="docs/public-exposure.md",
        errors=errors,
    ):
        fields = canonical_fields(raw_fields, PUBLIC_DOC_FIELD_ALIASES)
        record = RouteRecord(
            source="docs/public-exposure.md",
            location=f"### {heading}",
            fields=fields,
        )
        require_complete_record(record, errors)
        if is_inactive_exposure_record(fields):
            continue
        if record.route_identifier:
            records.append(record)
    return records


def service_doc_route_records(doc: str, errors: list[str]) -> list[RouteRecord]:
    records: list[RouteRecord] = []
    for heading, raw_fields in markdown_field_tables(
        doc,
        start_heading="Service Records",
        source="docs/services.md",
        errors=errors,
    ):
        fields = canonical_fields(raw_fields, SERVICE_DOC_FIELD_ALIASES)
        record = RouteRecord(
            source="docs/services.md",
            location=f"### {heading}",
            fields=fields,
        )
        validate_exposure_state(record, errors)
        if is_inactive_exposure_record(fields):
            require_complete_record(record, errors)
            continue
        public_exposure = fields.get("public_host_or_port", "")
        if not has_value(public_exposure):
            continue
        require_complete_record(record, errors)
        if record.route_identifier:
            records.append(record)
    return records


def describe_sources(route_id: str, sources: dict[str, set[str]]) -> tuple[list[str], list[str]]:
    present = sorted(source for source, ids in sources.items() if route_id in ids)
    missing = sorted(source for source, ids in sources.items() if route_id not in ids)
    return present, missing


def validate_route_alignment(
    inventory_records: list[RouteRecord],
    service_records: list[RouteRecord],
    public_records: list[RouteRecord],
    errors: list[str],
) -> None:
    records_by_source = {
        "inventory": records_by_route_id(inventory_records, errors),
        "docs/services.md": records_by_route_id(service_records, errors),
        "docs/public-exposure.md": records_by_route_id(public_records, errors),
    }
    sources = {source: set(records) for source, records in records_by_source.items()}
    all_route_ids = set().union(*sources.values())
    for route_id in sorted(all_route_ids):
        present, missing = describe_sources(route_id, sources)
        if missing:
            fail(
                errors,
                f"public route {route_id!r} appears in {', '.join(present)} "
                f"but is missing from {', '.join(missing)}",
            )
            continue

        canonical_by_source = {
            source: comparable_fields(records[route_id])
            for source, records in records_by_source.items()
        }
        for field in COMPARABLE_RECORD_FIELDS:
            values = {
                source: fields[field]
                for source, fields in canonical_by_source.items()
            }
            distinct_values = set(values.values())
            if len(distinct_values) > 1:
                formatted_values = "; ".join(
                    f"{source}={value!r}" for source, value in sorted(values.items())
                )
                fail(
                    errors,
                    f"public route {route_id!r} has mismatched "
                    f"{CANONICAL_FIELD_NAMES[field]}: {formatted_values}",
                )


def records_by_route_id(records: list[RouteRecord], errors: list[str]) -> dict[str, RouteRecord]:
    by_route_id: dict[str, RouteRecord] = {}
    for record in records:
        route_id = record.route_identifier
        if not route_id:
            continue
        if route_id in by_route_id:
            fail(
                errors,
                f"{record.source} contains duplicate public route identifier {route_id!r} "
                f"at {by_route_id[route_id].location} and {record.location}",
            )
            continue
        by_route_id[route_id] = record
    return by_route_id


def main() -> int:
    errors: list[str] = []
    inventory = load_yaml(INVENTORY, errors)
    public_doc = read_text(PUBLIC_EXPOSURE_DOC, errors)
    services_doc = read_text(SERVICES_DOC, errors)

    all_group = inventory.get("all") if isinstance(inventory, dict) else {}
    if not isinstance(all_group, dict):
        fail(errors, "inventory must contain an all group mapping")
        all_group = {}

    hosts = all_group.get("hosts") or {}
    if not isinstance(hosts, dict):
        fail(errors, "all.hosts must be a mapping")
        hosts = {}

    children = all_group.get("children") or {}
    if not isinstance(children, dict):
        fail(errors, "all.children must be a mapping")
        children = {}

    inventory_records = inventory_route_records(hosts, public_group_hosts(children, errors), errors)
    service_records = service_doc_route_records(services_doc, errors)
    public_records = public_doc_route_records(public_doc, errors)

    all_declared_routes = inventory_records + service_records + public_records
    public_doc_has_no_routes_statement = NO_PRODUCTION_ROUTES_STATEMENT in public_doc

    if not all_declared_routes:
        if not public_doc_has_no_routes_statement:
            fail(
                errors,
                "docs/public-exposure.md must explicitly state that no production public "
                "routes or ports have been declared while inventory and service docs declare none",
            )
    else:
        if public_doc_has_no_routes_statement:
            fail(
                errors,
                "docs/public-exposure.md still says no production public routes are declared, "
                "but at least one authoritative source contains public route metadata",
            )
        validate_route_alignment(inventory_records, service_records, public_records, errors)

    if errors:
        print("Public exposure documentation validation failed:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1

    print(
        "Public exposure documentation validation passed: "
        f"{INVENTORY.relative_to(ROOT)}, {SERVICES_DOC.relative_to(ROOT)}, "
        f"and {PUBLIC_EXPOSURE_DOC.relative_to(ROOT)} agree"
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""Run promotion evidence validator fixture cases in disposable repositories."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
VALIDATOR = ROOT / "scripts/validate-promotion-evidence"
FIXTURES = ROOT / "tests/fixtures/promotion-evidence"


@dataclass(frozen=True)
class FixtureCase:
    name: str
    should_pass: bool
    expected_output: str = ""


CASES = (
    FixtureCase(
        "stale-intake",
        False,
        "fully placeholder worksheet",
    ),
    FixtureCase("superseded-intake", True),
    FixtureCase("completed-intake", True),
    FixtureCase(
        "intake-storage-drift",
        False,
        "host lab-app-01: storage type mismatch",
    ),
    FixtureCase(
        "ambiguous-sops-proof",
        False,
        "must clearly state SOPS proof status",
    ),
    FixtureCase("valid-sops-proof", True),
    FixtureCase("sops-proof-reproduced", True),
    FixtureCase(
        "sops-proof-operator-provided",
        True,
        "not ready for real encrypted non-example secret material",
    ),
    FixtureCase(
        "sops-proof-not-yet-reproduced",
        True,
        "not ready for real encrypted non-example secret material",
    ),
    FixtureCase(
        "sops-proof-blocks-real-secret",
        False,
        "real encrypted non-example SOPS secrets require docs/sops-workflow-proof.md status: reproduced",
    ),
    FixtureCase(
        "sops-proof-outside-policy-operator-provided",
        False,
        "real encrypted non-example SOPS secrets require docs/sops-workflow-proof.md status: reproduced",
    ),
    FixtureCase(
        "sops-proof-outside-policy-reproduced",
        False,
        "encrypted non-example SOPS file is missing intended .sops.yaml creation rule coverage: clusters/homelab/outside-policy.sops.yaml",
    ),
    FixtureCase("sops-proof-reproduced-real-secret-covered", True),
    FixtureCase("sops-proof-operator-provided-ignored-encrypted-files", True),
)


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/validate-promotion-evidence"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(VALIDATOR, script_path)

    for source in fixture.rglob("*"):
        if not source.is_file():
            continue
        target = destination / source.relative_to(fixture)
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)

    return script_path


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"promotion-evidence-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        result = subprocess.run(
            [sys.executable, str(script_path)],
            cwd=tmp_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL promotion evidence fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS promotion evidence fixture: {case.name}")

    if failures:
        print("Promotion evidence validator fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Promotion evidence validator fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

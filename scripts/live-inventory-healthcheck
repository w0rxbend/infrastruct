#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
USAGE:
  scripts/live-inventory-healthcheck [host-or-group-limit]
  scripts/live-inventory-healthcheck --runner [host-or-group-limit]

Environment:
  ANSIBLE_LIMIT                  Host or group limit when no positional limit is provided.
  ANSIBLE_TIMEOUT                Ansible connection timeout. Defaults to 10.
  INVENTORY                      Inventory path. Defaults to ansible/inventories/homelab/hosts.yml.
  LIVE_INVENTORY_SSH_DIR         Optional external SSH directory mounted read-only at /tmp/.ssh in --runner mode.
  VALIDATION_RUNNER_ENGINE       Container engine for --runner: docker or podman.
  VALIDATION_RUNNER_IMAGE        Validation image tag for --runner.
  VALIDATION_RUNNER_SKIP_BUILD   Set to 1 to reuse an existing validation image.
EOF
}

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
repo_root="$(cd -- "${script_dir}/.." && pwd)"
inventory="${INVENTORY:-ansible/inventories/homelab/hosts.yml}"
runner_mode=0

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ "${1:-}" == "--runner" ]]; then
  runner_mode=1
  shift
fi

limit="${1:-${ANSIBLE_LIMIT:-all}}"
timeout="${ANSIBLE_TIMEOUT:-10}"

if [[ "$#" -gt 1 ]]; then
  usage >&2
  exit 2
fi

run_runner() {
  local image="${VALIDATION_RUNNER_IMAGE:-infrastruct-validate:local}"
  local engine="${VALIDATION_RUNNER_ENGINE:-}"
  local skip_build="${VALIDATION_RUNNER_SKIP_BUILD:-0}"
  local ssh_dir="${LIVE_INVENTORY_SSH_DIR:-}"
  local -a run_args=()
  local -a container_command=(scripts/live-inventory-healthcheck)

  if [[ -z "${engine}" ]]; then
    if command -v docker >/dev/null 2>&1; then
      engine=docker
    elif command -v podman >/dev/null 2>&1; then
      engine=podman
    else
      echo "MISSING TOOL: docker or podman is required for runner-backed live inventory healthcheck." >&2
      exit 127
    fi
  fi

  if ! command -v "${engine}" >/dev/null 2>&1; then
    echo "MISSING TOOL: ${engine} is not installed or is not on PATH." >&2
    exit 127
  fi

  if [[ -n "${ssh_dir}" && ! -d "${ssh_dir}" ]]; then
    echo "PREREQUISITE FAILURE: LIVE_INVENTORY_SSH_DIR must point to an existing SSH directory: ${ssh_dir}" >&2
    echo "Do not commit SSH keys or private authentication material; mount operator-managed auth material from outside the repository." >&2
    exit 2
  fi

  if [[ "${skip_build}" != "1" ]]; then
    echo "==> Building validation runner image for live inventory healthcheck: ${image}"
    "${engine}" build -f "${repo_root}/Containerfile" -t "${image}" "${repo_root}"
  fi

  run_args=(
    run
    --rm
  )

  if [[ "$(uname -s)" == "Linux" ]]; then
    run_args+=(--network host)
  else
    echo "WARNING: host networking is not enabled on this platform; container reachability may differ from the host." >&2
  fi

  run_args+=(
    -e HOME=/tmp
    -e PYTHONDONTWRITEBYTECODE=1
    -e XDG_CACHE_HOME=/tmp/.cache
    -e "INVENTORY=${inventory}"
    -e "ANSIBLE_TIMEOUT=${timeout}"
    --tmpfs /workspace/.ansible:rw,size=64m
    -v "${repo_root}:/workspace:ro"
    -w /workspace
  )

  if [[ -n "${ssh_dir}" ]]; then
    run_args+=(
      -v "${ssh_dir}:/tmp/.ssh:ro"
    )
  fi

  if [[ -n "${ANSIBLE_LIMIT:-}" ]]; then
    run_args+=(-e "ANSIBLE_LIMIT=${ANSIBLE_LIMIT}")
  fi

  if [[ "$#" -eq 1 ]]; then
    container_command+=("${limit}")
  fi

  echo "==> Running live inventory healthcheck in validation runner image: ${image}"
  "${engine}" "${run_args[@]}" "${image}" "${container_command[@]}"
}

if [[ "${runner_mode}" -eq 1 ]]; then
  run_runner "$@"
  exit 0
fi

if ! command -v ansible-inventory >/dev/null 2>&1; then
  echo "MISSING TOOL: ansible-inventory is required for live inventory healthcheck. Install ansible-core." >&2
  exit 127
fi

if ! command -v ansible >/dev/null 2>&1; then
  echo "MISSING TOOL: ansible is required for live inventory healthcheck. Install ansible-core." >&2
  exit 127
fi

if [[ ! -f "${inventory}" ]]; then
  echo "PREREQUISITE FAILURE: inventory file not found: ${inventory}" >&2
  exit 2
fi

tmpdir="$(mktemp -d)"
trap 'rm -rf "${tmpdir}"' EXIT

inventory_output="${tmpdir}/ansible-inventory.json"
ping_output="${tmpdir}/ansible-ping.out"

echo "==> Rendering inventory: ${inventory}"
if ! ansible-inventory -i "${inventory}" --list >"${inventory_output}"; then
  echo "PREREQUISITE FAILURE: ansible-inventory could not render ${inventory}." >&2
  echo "No live reachability check was run." >&2
  exit 2
fi

echo "OK: ansible-inventory rendered successfully."
echo "==> Running read-only reachability check: ansible ${limit} -i ${inventory} -m ansible.builtin.ping -e ansible_become=false"

set +e
ANSIBLE_BECOME=false ANSIBLE_TIMEOUT="${timeout}" ansible "${limit}" \
  -i "${inventory}" \
  -m ansible.builtin.ping \
  -e ansible_become=false \
  >"${ping_output}" 2>&1
status="$?"
set -e

cat "${ping_output}"

if [[ "${status}" -eq 0 ]]; then
  echo "OK: all targeted hosts responded to Ansible ping."
  exit 0
fi

if grep -Eq 'UNREACHABLE!|Failed to connect|No route to host|Connection timed out|Permission denied' "${ping_output}"; then
  echo "LIVE REACHABILITY FAILURE: one or more targeted hosts were unreachable or rejected the Ansible connection." >&2
  echo "Record each affected host and observed error before enabling any mutating baseline role." >&2
  exit 4
fi

echo "ANSIBLE EXECUTION FAILURE: ansible ping failed, but no unreachable-host marker was detected." >&2
echo "Treat this as a tool, authentication, inventory, or module execution defect and inspect the output above." >&2
exit "${status}"

#!/usr/bin/env python3
"""Validate audit-first operational readiness evidence."""

from __future__ import annotations

import importlib.util
import re
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:
    print("ERROR: PyYAML is required for operational readiness validation.", file=sys.stderr)
    sys.exit(1)


ROOT = Path(__file__).resolve().parents[1]
LIVE_EVIDENCE = ROOT / "docs/live-inventory-evidence.md"
PUBLIC_EXPOSURE_DISCOVERY = ROOT / "docs/public-exposure-discovery.md"
SOPS_PROOF = ROOT / "docs/sops-workflow-proof.md"
BASELINE_PLAYBOOK = ROOT / "ansible/playbooks/baseline.yml"
PUBLIC_EXPOSURE_VALIDATOR = ROOT / "scripts/validate-public-exposure-docs"

LIVE_STATUSES = ("not-yet-run", "partial", "reproduced")
PUBLIC_EXPOSURE_DISCOVERY_STATUSES = ("not-yet-run", "partial", "reproduced")
SOPS_STATUSES = ("reproduced", "operator-provided", "not-yet-reproduced")
REQUIRED_LIVE_EVIDENCE_FIELDS = (
    "command date",
    "runner or workstation identity",
    "ansible-core version",
    "inventory render result",
    "ping result",
    "reviewer",
    "follow-up owner",
    "follow-up action",
)
REQUIRED_PUBLIC_EXPOSURE_DISCOVERY_FIELDS = (
    "discovery date",
    "reviewer",
    "checked scope",
    "findings",
    "follow-up owner",
    "follow-up action",
)
PLACEHOLDER_VALUES = {
    "",
    "n/a",
    "na",
    "none",
    "not recorded",
    "not reviewed",
    "not run",
    "not yet assigned",
    "not yet reproduced",
    "not yet run",
    "not-yet-assigned",
    "not-yet-reproduced",
    "not-yet-run",
    "pending",
    "placeholder",
    "tbd",
    "todo",
    "unknown",
    "unset",
}
PLACEHOLDER_NORMALIZED_VALUES = {
    re.sub(r"[\s_-]+", "-", value) for value in PLACEHOLDER_VALUES
}
REQUIRED_SOPS_GATES = (
    ("encrypt/decrypt round trip", ("encrypt/decrypt", "round trip")),
    ("sops edit", ("sops edit",)),
    ("recipient rotation", ("recipient rotation", "updatekeys")),
    ("private identity backup recovery", ("recovery", "backup")),
)
NON_MUTATING_MODULES = {
    "ansible.builtin.assert",
    "ansible.builtin.debug",
    "ansible.builtin.fail",
    "ansible.builtin.include_vars",
    "ansible.builtin.set_fact",
    "assert",
    "debug",
    "fail",
    "include_vars",
    "set_fact",
}
TASK_METADATA_KEYS = {
    "action",
    "become",
    "changed_when",
    "check_mode",
    "delegate_to",
    "failed_when",
    "ignore_errors",
    "loop",
    "loop_control",
    "name",
    "notify",
    "register",
    "tags",
    "vars",
    "when",
    "with_items",
}
TEXT_SUFFIXES = {
    "",
    ".cfg",
    ".conf",
    ".env",
    ".ini",
    ".json",
    ".properties",
    ".txt",
    ".yaml",
    ".yml",
}
SKIP_SECRET_SCAN_DIRS = {
    ".git",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    "__pycache__",
    "docs",
    "scripts",
    "tests",
}
SKIP_SECRET_SCAN_PATHS = {
    Path(".sops.yaml"),
    Path("secrets/README.md"),
}

STATUS_PATTERN = re.compile(r"^\s*status\s*:\s*([A-Za-z0-9 -]+)", re.IGNORECASE | re.MULTILINE)
TABLE_STATUS_PATTERN = re.compile(
    r"^\s*\|\s*status\s*\|\s*`?([A-Za-z0-9 -]+)`?\s*\|",
    re.IGNORECASE | re.MULTILINE,
)
FIELD_PATTERN = re.compile(r"^\s*(?:[-*]\s*)?([A-Za-z][A-Za-z0-9 /-]*?):\s*(.*?)\s*$")
TABLE_FIELD_PATTERN = re.compile(r"^\s*\|\s*([^|]+?)\s*\|\s*(.*?)\s*\|\s*$")
GATE_HEADING_PATTERN = re.compile(r"^##\s+Evidence Gate\s+\d+\s*:\s*(.+?)\s*$", re.MULTILINE)
SOPS_ENCRYPTED_PATTERN = re.compile(r"(?m)^\s*[\"']?sops[\"']?\s*:")


def read_required_text(path: Path, errors: list[str]) -> str:
    try:
        return path.read_text(encoding="utf-8")
    except FileNotFoundError:
        errors.append(f"required operational readiness file is missing: {path.relative_to(ROOT)}")
        return ""


def normalize_status(raw_status: str) -> str:
    return re.sub(r"\s+", "-", raw_status.strip().rstrip(".").lower())


def parse_status(
    text: str,
    allowed_statuses: tuple[str, ...],
    label: str,
    errors: list[str],
) -> str | None:
    match = STATUS_PATTERN.search(text)
    if not match:
        match = TABLE_STATUS_PATTERN.search(text)
    if not match:
        errors.append(
            f"{label} must include an explicit Status field with one of: "
            f"{', '.join(allowed_statuses)}"
        )
        return None

    status = normalize_status(match.group(1))
    if status not in allowed_statuses:
        errors.append(
            f"{label} Status must be one of: {', '.join(allowed_statuses)}; "
            f"found {match.group(1).strip()!r}"
        )
        return None
    return status


def normalize_field_name(raw_name: str) -> str:
    return re.sub(r"\s+", " ", raw_name.strip().lower())


def normalize_evidence_value(raw_value: str) -> str:
    value = raw_value.strip().strip("`").strip()
    value = value.rstrip(".")
    return re.sub(r"\s+", " ", value.lower())


def normalize_placeholder_token(raw_value: str) -> str:
    return re.sub(r"[\s_-]+", "-", normalize_evidence_value(raw_value))


def is_placeholder_value(raw_value: str) -> bool:
    value = normalize_evidence_value(raw_value)
    token = normalize_placeholder_token(raw_value)
    if value in PLACEHOLDER_VALUES:
        return True
    if token in PLACEHOLDER_NORMALIZED_VALUES:
        return True
    return (
        token.startswith("not-recorded")
        or token.startswith("not-reviewed")
        or token.startswith("not-yet-assigned")
        or token.startswith("not-yet-reproduced")
        or token.startswith("not-yet-run")
    )


def parse_markdown_fields(text: str) -> dict[str, str]:
    fields: dict[str, str] = {}
    current_field: str | None = None

    for line in text.splitlines():
        table_match = TABLE_FIELD_PATTERN.match(line)
        if table_match:
            field_name = normalize_field_name(table_match.group(1))
            if field_name == "field" or set(table_match.group(1).strip()) <= {"-"}:
                current_field = None
                continue
            current_field = field_name
            fields[current_field] = table_match.group(2).strip()
            continue

        match = FIELD_PATTERN.match(line)
        if match:
            current_field = normalize_field_name(match.group(1))
            fields[current_field] = match.group(2).strip()
            continue

        if current_field and (line.startswith("  ") or line.startswith("\t")):
            continuation = line.strip()
            if continuation:
                fields[current_field] = f"{fields[current_field]} {continuation}".strip()
            continue

        current_field = None

    return fields


def validate_live_inventory_reproduced_fields(text: str, errors: list[str]) -> None:
    fields = parse_markdown_fields(text)
    for field in REQUIRED_LIVE_EVIDENCE_FIELDS:
        value = fields.get(field, "")
        if is_placeholder_value(value):
            errors.append(
                "docs/live-inventory-evidence.md Status is reproduced, but "
                f"{field!r} is missing or placeholder"
            )


def findings_state_zero_active_routes(raw_value: str) -> bool:
    value = normalize_evidence_value(raw_value)
    return (
        re.search(r"\bzero\s+active\s+production\s+public\s+routes?\b", value) is not None
        and "confirmed" in value
    )


def findings_state_active_routes_found(raw_value: str) -> bool:
    value = normalize_evidence_value(raw_value)
    return re.search(r"\bactive\s+production\s+public\s+routes?\s+(?:were\s+)?found\b", value) is not None


def public_exposure_route_register_state(errors: list[str]) -> tuple[list[str], int] | None:
    if not PUBLIC_EXPOSURE_VALIDATOR.is_file():
        errors.append(
            "docs/public-exposure-discovery.md Status is reproduced, but "
            "scripts/validate-public-exposure-docs is missing and the active route "
            "register cannot be checked"
        )
        return None

    spec = importlib.util.spec_from_file_location(
        "public_exposure_validator",
        PUBLIC_EXPOSURE_VALIDATOR,
        loader=SourceFileLoader("public_exposure_validator", str(PUBLIC_EXPOSURE_VALIDATOR)),
    )
    if spec is None or spec.loader is None:
        errors.append(
            "docs/public-exposure-discovery.md Status is reproduced, but "
            "scripts/validate-public-exposure-docs could not be loaded"
        )
        return None

    module = importlib.util.module_from_spec(spec)
    sys.modules[spec.name] = module
    spec.loader.exec_module(module)
    validate = getattr(module, "validate_public_exposure_documents", None)
    if validate is None:
        errors.append(
            "docs/public-exposure-discovery.md Status is reproduced, but "
            "scripts/validate-public-exposure-docs does not expose "
            "validate_public_exposure_documents()"
        )
        return None

    validator_errors, active_route_record_count = validate()
    return list(validator_errors), int(active_route_record_count)


def validate_public_exposure_discovery_route_register(findings: str, errors: list[str]) -> None:
    route_state = public_exposure_route_register_state(errors)
    if route_state is None:
        return
    route_errors, active_route_record_count = route_state

    if route_errors:
        errors.append(
            "docs/public-exposure-discovery.md Status is reproduced, but the active "
            "public exposure route register is not aligned: "
            + "; ".join(route_errors)
        )
        return

    if findings_state_zero_active_routes(findings) and active_route_record_count != 0:
        errors.append(
            "docs/public-exposure-discovery.md findings confirm zero active production "
            "public routes, but inventory, docs/services.md, and docs/public-exposure.md "
            f"contain {active_route_record_count} active production route record(s)"
        )
    elif findings_state_active_routes_found(findings) and active_route_record_count == 0:
        errors.append(
            "docs/public-exposure-discovery.md findings state that active production "
            "public routes were found, but inventory, docs/services.md, and "
            "docs/public-exposure.md contain zero active production route records"
        )


def validate_public_exposure_discovery_reproduced_fields(text: str, errors: list[str]) -> None:
    fields = parse_markdown_fields(text)
    for field in REQUIRED_PUBLIC_EXPOSURE_DISCOVERY_FIELDS:
        value = fields.get(field, "")
        if is_placeholder_value(value):
            errors.append(
                "docs/public-exposure-discovery.md Status is reproduced, but "
                f"{field!r} is missing or placeholder"
            )

    findings = fields.get("findings", "")
    if (
        not is_placeholder_value(findings)
        and not findings_state_zero_active_routes(findings)
        and not findings_state_active_routes_found(findings)
    ):
        errors.append(
            "docs/public-exposure-discovery.md Status is reproduced, but 'findings' "
            "must explicitly state that zero active production public routes were "
            "confirmed or that active production public routes were found"
        )
    elif not is_placeholder_value(findings):
        validate_public_exposure_discovery_route_register(findings, errors)


def parse_live_inventory_status(errors: list[str]) -> str | None:
    text = read_required_text(LIVE_EVIDENCE, errors)
    if not text:
        return None
    status = parse_status(text, LIVE_STATUSES, "docs/live-inventory-evidence.md", errors)
    if status == "reproduced":
        validate_live_inventory_reproduced_fields(text, errors)
    return status


def parse_public_exposure_discovery_status(errors: list[str]) -> str | None:
    text = read_required_text(PUBLIC_EXPOSURE_DISCOVERY, errors)
    if not text:
        return None
    status = parse_status(
        text,
        PUBLIC_EXPOSURE_DISCOVERY_STATUSES,
        "docs/public-exposure-discovery.md",
        errors,
    )
    if status == "reproduced":
        validate_public_exposure_discovery_reproduced_fields(text, errors)
    return status


def sops_gate_sections(text: str) -> dict[str, str]:
    matches = list(GATE_HEADING_PATTERN.finditer(text))
    sections: dict[str, str] = {}
    for index, match in enumerate(matches):
        start = match.end()
        end = matches[index + 1].start() if index + 1 < len(matches) else len(text)
        sections[match.group(1).strip().lower()] = text[start:end]
    return sections


def find_gate_section(sections: dict[str, str], fragments: tuple[str, ...]) -> tuple[str, str] | None:
    for title, section in sections.items():
        if any(fragment in title for fragment in fragments):
            return title, section
    return None


def parse_sops_statuses(errors: list[str]) -> tuple[str | None, dict[str, str]]:
    text = read_required_text(SOPS_PROOF, errors)
    if not text:
        return None, {}

    overall = parse_status(text, SOPS_STATUSES, "docs/sops-workflow-proof.md", errors)
    gate_sections = sops_gate_sections(text)
    gate_statuses: dict[str, str] = {}

    for gate_name, fragments in REQUIRED_SOPS_GATES:
        found = find_gate_section(gate_sections, fragments)
        if found is None:
            errors.append(f"docs/sops-workflow-proof.md is missing evidence gate: {gate_name}")
            continue
        title, section = found
        status = parse_status(
            section,
            SOPS_STATUSES,
            f"docs/sops-workflow-proof.md gate {title!r}",
            errors,
        )
        if status is not None:
            gate_statuses[gate_name] = status

    if overall == "reproduced":
        for gate_name, _fragments in REQUIRED_SOPS_GATES:
            gate_status = gate_statuses.get(gate_name)
            if gate_status != "reproduced":
                errors.append(
                    "docs/sops-workflow-proof.md overall Status is reproduced, but "
                    f"SOPS evidence gate {gate_name!r} is "
                    f"{gate_status or 'missing'}"
                )

    return overall, gate_statuses


def load_yaml_file(path: Path, errors: list[str]) -> Any:
    try:
        return yaml.safe_load(path.read_text(encoding="utf-8"))
    except FileNotFoundError:
        return None
    except yaml.YAMLError as exc:
        errors.append(f"{path.relative_to(ROOT)} does not parse: {exc}")
        return None


def role_names_from_play(play: Any) -> list[str]:
    if not isinstance(play, dict):
        return []
    roles = play.get("roles")
    if not isinstance(roles, list):
        return []

    names: list[str] = []
    for role in roles:
        if isinstance(role, str):
            names.append(role)
        elif isinstance(role, dict):
            role_name = role.get("role")
            if isinstance(role_name, str):
                names.append(role_name)
    return names


def task_module_names(task: Any) -> set[str]:
    if not isinstance(task, dict):
        return set()

    modules: set[str] = set()
    action = task.get("action")
    if isinstance(action, str):
        modules.add(action.split()[0])
    elif isinstance(action, dict):
        module = action.get("module")
        if isinstance(module, str):
            modules.add(module)

    for key in task:
        if key not in TASK_METADATA_KEYS:
            modules.add(str(key))
    return modules


def role_has_mutating_tasks(role_name: str, errors: list[str]) -> bool:
    tasks_path = ROOT / "ansible/roles" / role_name / "tasks/main.yml"
    data = load_yaml_file(tasks_path, errors)
    if data is None:
        return False
    if not isinstance(data, list):
        errors.append(f"{tasks_path.relative_to(ROOT)} must be a list of Ansible tasks")
        return True

    for task in data:
        modules = task_module_names(task)
        if not modules:
            continue
        if any(module not in NON_MUTATING_MODULES for module in modules):
            return True
    return False


def enabled_mutating_baseline_roles(errors: list[str]) -> list[str]:
    data = load_yaml_file(BASELINE_PLAYBOOK, errors)
    if data is None:
        return []
    if not isinstance(data, list):
        errors.append("ansible/playbooks/baseline.yml must be a list of plays")
        return []

    role_names: list[str] = []
    for play in data:
        role_names.extend(role_names_from_play(play))

    mutating_roles: list[str] = []
    for role_name in sorted(set(role_names)):
        if role_name == "inventory_assertions":
            continue
        if role_has_mutating_tasks(role_name, errors):
            mutating_roles.append(role_name)
    return mutating_roles


def is_example_path(path: Path) -> bool:
    return any("example" in part.lower() for part in path.parts)


def should_scan_for_real_secret(path: Path) -> bool:
    if path in SKIP_SECRET_SCAN_PATHS:
        return False
    if path.suffix not in TEXT_SUFFIXES:
        return False
    if is_example_path(path):
        return False
    if any(part in SKIP_SECRET_SCAN_DIRS for part in path.parts):
        return False
    return True


def is_sops_encrypted(text: str) -> bool:
    return "ENC[" in text and SOPS_ENCRYPTED_PATTERN.search(text) is not None


def encrypted_non_example_sops_paths() -> list[Path]:
    encrypted_paths: list[Path] = []
    for absolute_path in ROOT.rglob("*"):
        if not absolute_path.is_file():
            continue
        relative_path = absolute_path.relative_to(ROOT)
        if not should_scan_for_real_secret(relative_path):
            continue
        try:
            text = absolute_path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            continue
        if is_sops_encrypted(text):
            encrypted_paths.append(relative_path)
    return sorted(encrypted_paths)


def main() -> int:
    errors: list[str] = []
    infos: list[str] = []

    live_status = parse_live_inventory_status(errors)
    public_exposure_discovery_status = parse_public_exposure_discovery_status(errors)
    _overall_sops_status, sops_gate_statuses = parse_sops_statuses(errors)

    mutating_roles = enabled_mutating_baseline_roles(errors)
    if mutating_roles and live_status != "reproduced":
        errors.append(
            "mutating baseline roles are enabled before live inventory evidence is "
            f"reproduced; live inventory status is {live_status or 'missing'}; "
            f"mutating role(s): {', '.join(mutating_roles)}"
        )

    encrypted_paths = encrypted_non_example_sops_paths()
    unreproduced_gates = [
        gate_name
        for gate_name, _fragments in REQUIRED_SOPS_GATES
        if sops_gate_statuses.get(gate_name) != "reproduced"
    ]
    if encrypted_paths and unreproduced_gates:
        errors.append(
            "real encrypted non-example SOPS files require every required SOPS "
            "evidence gate to be reproduced; encrypted path(s): "
            f"{', '.join(path.as_posix() for path in encrypted_paths)}; "
            f"unreproduced gate(s): {', '.join(unreproduced_gates)}"
        )

    if live_status and live_status != "reproduced":
        infos.append(
            f"live inventory evidence status is {live_status}; mutating baseline roles "
            "must remain disabled or placeholder-only until it is reproduced"
        )
    if sops_gate_statuses and unreproduced_gates:
        infos.append(
            "SOPS evidence gates are not all reproduced; real encrypted non-example "
            "SOPS files remain blocked"
        )
    if public_exposure_discovery_status and public_exposure_discovery_status != "reproduced":
        infos.append(
            "public exposure discovery evidence status is "
            f"{public_exposure_discovery_status}; the zero-active-public-route claim "
            "remains pending reviewed live discovery"
        )

    if errors:
        print("Operational readiness validation failed:", file=sys.stderr)
        for error in errors:
            print(f"- {error}", file=sys.stderr)
        return 1

    for info in infos:
        print(f"INFO: {info}")
    print("Operational readiness validation passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

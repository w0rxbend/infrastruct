#!/usr/bin/env python3
"""Run public exposure validator fixture cases in disposable repo copies."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
VALIDATOR = ROOT / "scripts/validate-public-exposure-docs"
FIXTURES = ROOT / "tests/fixtures/public-exposure"


@dataclass(frozen=True)
class FixtureCase:
    name: str
    should_pass: bool
    expected_output: str = ""


CASES = (
    FixtureCase("empty-production", True),
    FixtureCase("complete-positive-route", True),
    FixtureCase("valid-non-public-service-states", True),
    FixtureCase("invalid-non-public-service-state", False, "has invalid exposure state"),
    FixtureCase("planned-unknown-placeholder", True),
    FixtureCase("active-unknown-placeholder", False, "is missing required fields"),
    FixtureCase(
        "service-only-public-host-alias",
        False,
        "appears in docs/services.md but is missing from docs/public-exposure.md, inventory",
    ),
    FixtureCase(
        "public-doc-only-route",
        False,
        "appears in docs/public-exposure.md but is missing from docs/services.md, inventory",
    ),
    FixtureCase("missing-required-fields", False, "is missing required fields"),
    FixtureCase("mismatched-runtime", False, "mismatched runtime"),
    FixtureCase("mismatched-public-host-or-port", False, "mismatched public host or port"),
    FixtureCase("mismatched-target", False, "mismatched target"),
    FixtureCase("mismatched-host-or-cluster", False, "mismatched target host or cluster"),
    FixtureCase("mismatched-protocol", False, "mismatched protocol"),
    FixtureCase("mismatched-proxy-owner", False, "mismatched proxy owner"),
    FixtureCase("mismatched-firewall-intent", False, "mismatched firewall intent"),
    FixtureCase("mismatched-secret-dependency", False, "mismatched secret dependency"),
    FixtureCase("mismatched-review-notes", False, "mismatched review notes"),
    FixtureCase("duplicate-route-ids", False, "duplicate public route identifier"),
    FixtureCase("malformed-route-table", False, "malformed Markdown table row"),
    FixtureCase(
        "stale-no-routes-statement",
        False,
        "still says no production public routes are declared",
    ),
)


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/validate-public-exposure-docs"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(VALIDATOR, script_path)

    file_map = {
        fixture / "hosts.yml": destination / "ansible/inventories/homelab/hosts.yml",
        fixture / "services.md": destination / "docs/services.md",
        fixture / "public-exposure.md": destination / "docs/public-exposure.md",
    }
    for source, target in file_map.items():
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)
    return script_path


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"public-exposure-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        result = subprocess.run(
            [sys.executable, str(script_path)],
            cwd=tmp_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL public exposure fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS public exposure fixture: {case.name}")

    if failures:
        print("Public exposure validator fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Public exposure validator fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""Run secret scanner fixture cases in disposable repo copies."""

from __future__ import annotations

import shutil
import subprocess
import sys
import tempfile
from dataclasses import dataclass
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]
SCANNER = ROOT / "scripts/scan-secrets"
FIXTURES = ROOT / "tests/fixtures/secret-scanner"


@dataclass(frozen=True)
class FixtureCase:
    name: str
    should_pass: bool
    expected_output: str = ""


CASES = (
    FixtureCase("clean-placeholders", True),
    FixtureCase("allowlisted-fake-secret", True),
    FixtureCase("ignored-example-path", True),
    FixtureCase("binary-env-file", True),
    FixtureCase("sops-suffixed-encrypted-file", True),
    FixtureCase(
        "plaintext-secret-assignment",
        False,
        "plaintext-looking secret assignment for API_TOKEN",
    ),
    FixtureCase(
        "lowercase-secret-assignment",
        False,
        "plaintext-looking secret assignment for api_token",
    ),
    FixtureCase(
        "mixed-case-secret-assignment",
        False,
        "plaintext-looking secret assignment for ClientSecret",
    ),
    FixtureCase("private-key-marker", False, "private key material marker"),
    FixtureCase("sops-encrypted-file", True),
)


def materialized_path(path: Path) -> Path:
    if path.name.endswith(".fixture"):
        return path.with_name(path.name.removesuffix(".fixture"))
    return path


def copy_fixture_repo(fixture: Path, destination: Path) -> Path:
    script_path = destination / "scripts/scan-secrets"
    script_path.parent.mkdir(parents=True)
    shutil.copy2(SCANNER, script_path)

    for source in fixture.rglob("*"):
        if not source.is_file():
            continue
        relative = materialized_path(source.relative_to(fixture))
        target = destination / relative
        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(source, target)

    return script_path


def run_case(case: FixtureCase) -> list[str]:
    fixture = FIXTURES / case.name
    if not fixture.is_dir():
        return [f"{case.name}: missing fixture directory {fixture.relative_to(ROOT)}"]

    with tempfile.TemporaryDirectory(prefix=f"secret-scanner-{case.name}-") as tmpdir:
        tmp_root = Path(tmpdir)
        script_path = copy_fixture_repo(fixture, tmp_root)
        result = subprocess.run(
            [sys.executable, str(script_path)],
            cwd=tmp_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    failures: list[str] = []
    if case.should_pass and result.returncode != 0:
        failures.append(f"{case.name}: expected pass, got exit {result.returncode}\n{output}")
    if not case.should_pass and result.returncode == 0:
        failures.append(f"{case.name}: expected failure, got pass\n{output}")
    if case.expected_output and case.expected_output not in output:
        failures.append(
            f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"
        )
    return failures


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL secret scanner fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS secret scanner fixture: {case.name}")

    if failures:
        print("Secret scanner fixture tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Secret scanner fixture tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

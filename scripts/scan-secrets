#!/usr/bin/env python3
"""Catch obvious plaintext secret assignments in committed configuration."""

from __future__ import annotations

import re
import sys
from pathlib import Path


ROOT = Path(__file__).resolve().parents[1]

SKIP_DIRS = {
    ".git",
    ".cache",
    ".mypy_cache",
    ".pytest_cache",
    ".ruff_cache",
    ".tox",
    ".venv",
    "env",
    "venv",
    "__pycache__",
}

SKIP_PATH_PREFIXES = (
    Path("ansible/inventories/examples"),
)

SKIP_FILES = {
    Path(".sops.yaml"),
    Path("scripts/scan-secrets"),
}

TEXT_SUFFIXES = {
    ".cfg",
    ".conf",
    ".env",
    ".ini",
    ".json",
    ".md",
    ".properties",
    ".sh",
    ".txt",
    ".yaml",
    ".yml",
}

ASSIGNMENT_RE = re.compile(
    r"""(?ix)
    ^\s*
    (?P<key>[A-Z0-9_.-]*(?:PASSWORD|PASSWD|PWD|TOKEN|API[_-]?KEY|SECRET|PRIVATE[_-]?KEY|CLIENT[_-]?SECRET|ACCESS[_-]?KEY)[A-Z0-9_.-]*)
    \s*[:=]\s*
    (?P<value>.+?)
    \s*$
    """
)

SAFE_VALUES = {
    "",
    "false",
    "null",
    "none",
    "not-required",
    "placeholder",
    "example",
    "dummy",
    "changeme",
    "change-me",
    "replace-before-use",
}

SAFE_VALUE_PREFIXES = (
    "ENC[",
    "{{",
    "${",
    "<",
)


def is_under(path: Path, prefix: Path) -> bool:
    try:
        path.relative_to(prefix)
    except ValueError:
        return False
    return True


def should_scan(path: Path) -> bool:
    rel = path.relative_to(ROOT)
    if rel in SKIP_FILES:
        return False
    if any(is_under(rel, prefix) for prefix in SKIP_PATH_PREFIXES):
        return False
    if ".sops." in path.name or path.name.endswith(".enc.yaml") or path.name.endswith(".enc.yml"):
        return False
    return path.suffix in TEXT_SUFFIXES


def is_sops_encrypted(text: str) -> bool:
    return "sops:" in text and "ENC[" in text


def value_is_safe(value: str) -> bool:
    cleaned = value.strip().strip("'\"")
    lowered = cleaned.lower()
    if lowered in SAFE_VALUES:
        return True
    if any(cleaned.startswith(prefix) for prefix in SAFE_VALUE_PREFIXES):
        return True
    return False


def scan_file(path: Path) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8")
    except UnicodeDecodeError:
        return []

    if is_sops_encrypted(text):
        return []

    findings: list[str] = []
    for line_number, line in enumerate(text.splitlines(), start=1):
        if "pragma: allowlist secret" in line:
            continue

        assignment = ASSIGNMENT_RE.match(line)
        if assignment:
            key = assignment.group("key")
            value = assignment.group("value").split("#", 1)[0].strip()
            if not value_is_safe(value):
                findings.append(f"{path.relative_to(ROOT)}:{line_number}: plaintext-looking secret assignment for {key}")
            continue

        lowered = line.lower()
        if "private key" in lowered and "begin " in lowered:
            findings.append(f"{path.relative_to(ROOT)}:{line_number}: private key material marker")

    return findings


def main() -> int:
    findings: list[str] = []
    for path in sorted(ROOT.rglob("*")):
        if not path.is_file():
            continue
        rel_parts = path.relative_to(ROOT).parts
        if any(part in SKIP_DIRS for part in rel_parts):
            continue
        if should_scan(path):
            findings.extend(scan_file(path))

    if findings:
        print("Secret scan failed:", file=sys.stderr)
        for finding in findings:
            print(f"- {finding}", file=sys.stderr)
        print("Use SOPS for real secrets, or add '# pragma: allowlist secret' for documented fake values.", file=sys.stderr)
        return 1

    print("Secret scan passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

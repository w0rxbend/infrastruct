#!/usr/bin/env python3
"""Validate inventory assertion role safety contracts."""

from __future__ import annotations

import sys
import shutil
import subprocess
import tempfile
from dataclasses import dataclass
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:  # pragma: no cover - exercised by workstation setup, not fixtures
    print("ERROR: PyYAML is required for inventory assertion contract tests.", file=sys.stderr)
    sys.exit(2)


ROOT = Path(__file__).resolve().parents[1]
BASELINE_PLAYBOOK = ROOT / "ansible/playbooks/baseline.yml"
FIXTURES = ROOT / "tests/fixtures/inventory-assertions"
ROLE_FIXTURES = FIXTURES / "cases.yml"


@dataclass(frozen=True)
class PlaybookCase:
    name: str
    path: Path
    should_pass: bool
    expected_output: str = ""


@dataclass(frozen=True)
class RoleCase:
    name: str
    should_pass: bool
    expected_output: str = ""
    group_names: tuple[str, ...] = ()
    host_vars: dict[str, Any] | None = None
    remove_fields: tuple[str, ...] = ()


CASES = (
    PlaybookCase("baseline", BASELINE_PLAYBOOK, True),
    PlaybookCase(
        "inherits-play-become",
        FIXTURES / "inherits-play-become/baseline.yml",
        False,
        "inventory_assertions must set become: false",
    ),
)


REQUIRED_FIXTURE_CONTRACT_VARS = (
    "required_host_fields",
    "allowed_architectures",
    "allowed_storage_types",
    "allowed_runtime_roles",
    "public_exposure_required_fields",
)


def load_playbook(path: Path) -> tuple[list[object] | None, str | None]:
    if not path.exists():
        return None, f"missing playbook {path.relative_to(ROOT)}"
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        return None, f"could not parse {path.relative_to(ROOT)}: {exc}"
    if not isinstance(data, list):
        return None, f"{path.relative_to(ROOT)} root must be a play list"
    return data, None


def role_name(role_entry: object) -> str | None:
    if isinstance(role_entry, str):
        return role_entry
    if isinstance(role_entry, dict) and isinstance(role_entry.get("role"), str):
        return role_entry["role"]
    return None


def validate_inventory_assertions_become(playbook: list[object], path: Path) -> list[str]:
    failures: list[str] = []
    for play_index, play in enumerate(playbook, start=1):
        if not isinstance(play, dict):
            continue
        roles = play.get("roles", [])
        if roles is None:
            roles = []
        if not isinstance(roles, list):
            failures.append(f"{path.relative_to(ROOT)} play {play_index} roles must be a list")
            continue

        for role_index, role in enumerate(roles, start=1):
            if role_name(role) != "inventory_assertions":
                continue
            if not isinstance(role, dict):
                failures.append(
                    f"{path.relative_to(ROOT)} play {play_index} role {role_index}: "
                    "inventory_assertions must set become: false and cannot be a bare role name"
                )
                continue
            if role.get("become") is not False:
                failures.append(
                    f"{path.relative_to(ROOT)} play {play_index} role {role_index}: "
                    "inventory_assertions must set become: false so it cannot inherit play-level privilege"
                )

    if not any(
        isinstance(play, dict)
        and any(role_name(role) == "inventory_assertions" for role in play.get("roles", []) or [])
        for play in playbook
    ):
        failures.append(f"{path.relative_to(ROOT)} does not include the inventory_assertions role")
    return failures


def run_case(case: PlaybookCase) -> list[str]:
    playbook, load_error = load_playbook(case.path)
    failures: list[str] = []
    if load_error is not None:
        failures.append(load_error)
    else:
        failures.extend(validate_inventory_assertions_become(playbook or [], case.path))

    output = "\n".join(failures)
    if case.should_pass and failures:
        return [f"{case.name}: expected pass, got failure\n{output}"]
    if not case.should_pass and not failures:
        return [f"{case.name}: expected failure, got pass"]
    if case.expected_output and case.expected_output not in output:
        return [f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"]
    return []


def merge_dict(base: dict[str, Any], updates: dict[str, Any]) -> dict[str, Any]:
    merged = dict(base)
    for key, value in updates.items():
        if isinstance(value, dict) and isinstance(merged.get(key), dict):
            merged[key] = merge_dict(merged[key], value)
        else:
            merged[key] = value
    return merged


def load_role_cases() -> tuple[list[RoleCase], list[str]]:
    if not ROLE_FIXTURES.exists():
        return [], [f"missing role fixture manifest {ROLE_FIXTURES.relative_to(ROOT)}"]

    try:
        data = yaml.safe_load(ROLE_FIXTURES.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        return [], [f"could not parse {ROLE_FIXTURES.relative_to(ROOT)}: {exc}"]

    if not isinstance(data, dict):
        return [], [f"{ROLE_FIXTURES.relative_to(ROOT)} root must be a mapping"]

    defaults = data.get("defaults")
    raw_cases = data.get("cases")
    if not isinstance(defaults, dict) or not isinstance(raw_cases, list):
        return [], [f"{ROLE_FIXTURES.relative_to(ROOT)} must define defaults and cases"]

    default_group_names = defaults.get("group_names")
    default_host_vars = defaults.get("host_vars")
    if not isinstance(default_group_names, list) or not all(isinstance(item, str) for item in default_group_names):
        return [], ["inventory assertion fixture defaults.group_names must be a list of strings"]
    if not isinstance(default_host_vars, dict):
        return [], ["inventory assertion fixture defaults.host_vars must be a mapping"]
    for var_name in REQUIRED_FIXTURE_CONTRACT_VARS:
        value = default_host_vars.get(var_name)
        if not isinstance(value, list) or isinstance(value, str):
            return [], [f"inventory assertion fixture defaults.host_vars.{var_name} must be a list"]

    failures: list[str] = []
    cases: list[RoleCase] = []
    for index, raw_case in enumerate(raw_cases, start=1):
        if not isinstance(raw_case, dict):
            failures.append(f"role fixture case {index} must be a mapping")
            continue

        name = raw_case.get("name")
        should_pass = raw_case.get("should_pass")
        if not isinstance(name, str) or not name.strip():
            failures.append(f"role fixture case {index} must define a non-empty name")
            continue
        if not isinstance(should_pass, bool):
            failures.append(f"role fixture case {name} must define boolean should_pass")
            continue

        group_names = raw_case.get("group_names", default_group_names)
        if not isinstance(group_names, list) or not all(isinstance(item, str) for item in group_names):
            failures.append(f"role fixture case {name} group_names must be a list of strings")
            continue

        host_updates = raw_case.get("host_vars", {})
        if not isinstance(host_updates, dict):
            failures.append(f"role fixture case {name} host_vars must be a mapping")
            continue
        host_vars = merge_dict(default_host_vars, host_updates)

        remove_fields = raw_case.get("remove_fields", [])
        if not isinstance(remove_fields, list) or not all(isinstance(item, str) for item in remove_fields):
            failures.append(f"role fixture case {name} remove_fields must be a list of strings")
            continue
        for field in remove_fields:
            host_vars.pop(field, None)

        expected_output = raw_case.get("expected_output", "")
        if not isinstance(expected_output, str):
            failures.append(f"role fixture case {name} expected_output must be a string")
            continue

        cases.append(
            RoleCase(
                name=name,
                should_pass=should_pass,
                expected_output=expected_output,
                group_names=tuple(group_names),
                host_vars=host_vars,
                remove_fields=tuple(remove_fields),
            )
        )

    return cases, failures


def inventory_for_role_case(case: RoleCase, defaults: dict[str, Any]) -> dict[str, Any]:
    host_vars = dict(case.host_vars or {})
    inventory_hostname = host_vars.pop("inventory_hostname", "fixture-host")
    group_vars = {
        key: host_vars.pop(key)
        for key in REQUIRED_FIXTURE_CONTRACT_VARS
        if key in host_vars
    }
    group_vars.setdefault("required_host_fields", defaults["host_vars"]["required_host_fields"])
    group_vars.setdefault("allowed_architectures", defaults["host_vars"]["allowed_architectures"])
    group_vars.setdefault("allowed_storage_types", defaults["host_vars"]["allowed_storage_types"])
    group_vars.setdefault("allowed_runtime_roles", defaults["host_vars"]["allowed_runtime_roles"])
    group_vars.setdefault(
        "public_exposure_required_fields",
        defaults["host_vars"]["public_exposure_required_fields"],
    )

    children = {
        group_name: {"hosts": {inventory_hostname: {}}}
        for group_name in case.group_names
    }
    return {
        "all": {
            "vars": group_vars,
            "hosts": {inventory_hostname: host_vars},
            "children": children,
        }
    }


def run_ansible_role_case(case: RoleCase, defaults: dict[str, Any], ansible_playbook: str) -> list[str]:
    with tempfile.TemporaryDirectory(prefix=f"inventory-assertions-{case.name}-") as tmpdir:
        tmp_path = Path(tmpdir)
        inventory_path = tmp_path / "hosts.yml"
        playbook_path = tmp_path / "assert.yml"

        inventory_path.write_text(
            yaml.safe_dump(inventory_for_role_case(case, defaults), sort_keys=False),
            encoding="utf-8",
        )
        playbook_path.write_text(
            "\n".join(
                [
                    "---",
                    "- name: Inventory assertion fixture",
                    "  hosts: all",
                    "  gather_facts: false",
                    "  connection: local",
                    "  roles:",
                    "    - role: inventory_assertions",
                    "",
                ]
            ),
            encoding="utf-8",
        )

        result = subprocess.run(
            [ansible_playbook, "-i", str(inventory_path), str(playbook_path)],
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    if case.should_pass and result.returncode != 0:
        return [f"{case.name}: ansible role expected pass, got exit {result.returncode}\n{output}"]
    if not case.should_pass and result.returncode == 0:
        return [f"{case.name}: ansible role expected failure, got pass\n{output}"]
    if case.expected_output and case.expected_output not in output:
        return [
            f"{case.name}: ansible role expected output fragment not found: "
            f"{case.expected_output!r}\n{output}"
        ]
    return []


def main() -> int:
    failures: list[str] = []
    semantic_cases_run = 0
    semantic_cases_skipped = 0

    print("Inventory assertion static checks:")
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL static check: {case.name}", file=sys.stderr)
        else:
            print(f"PASS static check: {case.name}")

    role_manifest, role_load_failures = load_role_cases()
    failures.extend(role_load_failures)
    if not role_load_failures:
        defaults = yaml.safe_load(ROLE_FIXTURES.read_text(encoding="utf-8"))["defaults"]
        for case in role_manifest:
            try:
                inventory_for_role_case(case, defaults)
            except (KeyError, TypeError, ValueError) as exc:
                failures.append(f"{case.name}: could not render Ansible fixture inventory: {exc}")
                print(f"FAIL static fixture manifest render: {case.name}", file=sys.stderr)
            else:
                print(f"PASS static fixture manifest render: {case.name}")

        print("Inventory assertion semantic Ansible role fixtures:")
        ansible_playbook = shutil.which("ansible-playbook")
        if ansible_playbook is None:
            skip_reason = "ansible-playbook is not installed; real role fixture execution was not run"
            for case in role_manifest:
                semantic_cases_skipped += 1
                print(f"SKIP semantic Ansible fixture: {case.name} ({skip_reason})")
        else:
            for case in role_manifest:
                semantic_cases_run += 1
                ansible_failures = run_ansible_role_case(case, defaults, ansible_playbook)
                if ansible_failures:
                    failures.extend(ansible_failures)
                    print(
                        f"FAIL semantic Ansible fixture: {case.name}",
                        file=sys.stderr,
                    )
                else:
                    print(f"PASS semantic Ansible fixture: {case.name}")

    if failures:
        print("Inventory assertion contract tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    if semantic_cases_run:
        print("Inventory assertion static checks and semantic Ansible fixtures passed.")
    elif semantic_cases_skipped:
        print(
            "Inventory assertion static checks passed; "
            "semantic Ansible fixtures were skipped because ansible-playbook is unavailable."
        )
    else:
        print("Inventory assertion static checks passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""Validate inventory assertion role safety contracts."""

from __future__ import annotations

import sys
import shutil
import subprocess
import tempfile
from dataclasses import dataclass
from pathlib import Path
from typing import Any

try:
    import yaml
except ImportError:  # pragma: no cover - exercised by workstation setup, not fixtures
    print("ERROR: PyYAML is required for inventory assertion contract tests.", file=sys.stderr)
    sys.exit(2)


ROOT = Path(__file__).resolve().parents[1]
BASELINE_PLAYBOOK = ROOT / "ansible/playbooks/baseline.yml"
FIXTURES = ROOT / "tests/fixtures/inventory-assertions"
ROLE_FIXTURES = FIXTURES / "cases.yml"


@dataclass(frozen=True)
class PlaybookCase:
    name: str
    path: Path
    should_pass: bool
    expected_output: str = ""


@dataclass(frozen=True)
class RoleCase:
    name: str
    should_pass: bool
    expected_output: str = ""
    group_names: tuple[str, ...] = ()
    host_vars: dict[str, Any] | None = None
    remove_fields: tuple[str, ...] = ()


CASES = (
    PlaybookCase("baseline", BASELINE_PLAYBOOK, True),
    PlaybookCase(
        "inherits-play-become",
        FIXTURES / "inherits-play-become/baseline.yml",
        False,
        "inventory_assertions must set become: false",
    ),
)


RUNTIME_ROLE_GROUPS = {
    "k3s_server": "k3s_servers",
    "k3s_agent": "k3s_agents",
    "docker_host": "docker_hosts",
    "swarm_manager": "swarm_managers",
    "swarm_worker": "swarm_workers",
    "edge_node": "edge_nodes",
}

ARCHITECTURE_GROUPS = {
    "arm64": "arm64",
    "armv7": "armv7",
}

STORAGE_GROUPS = {
    "ssd": "ssd_storage",
    "sdcard": "sdcard_storage",
}


def load_playbook(path: Path) -> tuple[list[object] | None, str | None]:
    if not path.exists():
        return None, f"missing playbook {path.relative_to(ROOT)}"
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        return None, f"could not parse {path.relative_to(ROOT)}: {exc}"
    if not isinstance(data, list):
        return None, f"{path.relative_to(ROOT)} root must be a play list"
    return data, None


def role_name(role_entry: object) -> str | None:
    if isinstance(role_entry, str):
        return role_entry
    if isinstance(role_entry, dict) and isinstance(role_entry.get("role"), str):
        return role_entry["role"]
    return None


def validate_inventory_assertions_become(playbook: list[object], path: Path) -> list[str]:
    failures: list[str] = []
    for play_index, play in enumerate(playbook, start=1):
        if not isinstance(play, dict):
            continue
        roles = play.get("roles", [])
        if roles is None:
            roles = []
        if not isinstance(roles, list):
            failures.append(f"{path.relative_to(ROOT)} play {play_index} roles must be a list")
            continue

        for role_index, role in enumerate(roles, start=1):
            if role_name(role) != "inventory_assertions":
                continue
            if not isinstance(role, dict):
                failures.append(
                    f"{path.relative_to(ROOT)} play {play_index} role {role_index}: "
                    "inventory_assertions must set become: false and cannot be a bare role name"
                )
                continue
            if role.get("become") is not False:
                failures.append(
                    f"{path.relative_to(ROOT)} play {play_index} role {role_index}: "
                    "inventory_assertions must set become: false so it cannot inherit play-level privilege"
                )

    if not any(
        isinstance(play, dict)
        and any(role_name(role) == "inventory_assertions" for role in play.get("roles", []) or [])
        for play in playbook
    ):
        failures.append(f"{path.relative_to(ROOT)} does not include the inventory_assertions role")
    return failures


def run_case(case: PlaybookCase) -> list[str]:
    playbook, load_error = load_playbook(case.path)
    failures: list[str] = []
    if load_error is not None:
        failures.append(load_error)
    else:
        failures.extend(validate_inventory_assertions_become(playbook or [], case.path))

    output = "\n".join(failures)
    if case.should_pass and failures:
        return [f"{case.name}: expected pass, got failure\n{output}"]
    if not case.should_pass and not failures:
        return [f"{case.name}: expected failure, got pass"]
    if case.expected_output and case.expected_output not in output:
        return [f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"]
    return []


def merge_dict(base: dict[str, Any], updates: dict[str, Any]) -> dict[str, Any]:
    merged = dict(base)
    for key, value in updates.items():
        if isinstance(value, dict) and isinstance(merged.get(key), dict):
            merged[key] = merge_dict(merged[key], value)
        else:
            merged[key] = value
    return merged


def load_role_cases() -> tuple[list[RoleCase], list[str]]:
    if not ROLE_FIXTURES.exists():
        return [], [f"missing role fixture manifest {ROLE_FIXTURES.relative_to(ROOT)}"]

    try:
        data = yaml.safe_load(ROLE_FIXTURES.read_text(encoding="utf-8"))
    except yaml.YAMLError as exc:
        return [], [f"could not parse {ROLE_FIXTURES.relative_to(ROOT)}: {exc}"]

    if not isinstance(data, dict):
        return [], [f"{ROLE_FIXTURES.relative_to(ROOT)} root must be a mapping"]

    defaults = data.get("defaults")
    raw_cases = data.get("cases")
    if not isinstance(defaults, dict) or not isinstance(raw_cases, list):
        return [], [f"{ROLE_FIXTURES.relative_to(ROOT)} must define defaults and cases"]

    default_group_names = defaults.get("group_names")
    default_host_vars = defaults.get("host_vars")
    if not isinstance(default_group_names, list) or not all(isinstance(item, str) for item in default_group_names):
        return [], ["inventory assertion fixture defaults.group_names must be a list of strings"]
    if not isinstance(default_host_vars, dict):
        return [], ["inventory assertion fixture defaults.host_vars must be a mapping"]

    failures: list[str] = []
    cases: list[RoleCase] = []
    for index, raw_case in enumerate(raw_cases, start=1):
        if not isinstance(raw_case, dict):
            failures.append(f"role fixture case {index} must be a mapping")
            continue

        name = raw_case.get("name")
        should_pass = raw_case.get("should_pass")
        if not isinstance(name, str) or not name.strip():
            failures.append(f"role fixture case {index} must define a non-empty name")
            continue
        if not isinstance(should_pass, bool):
            failures.append(f"role fixture case {name} must define boolean should_pass")
            continue

        group_names = raw_case.get("group_names", default_group_names)
        if not isinstance(group_names, list) or not all(isinstance(item, str) for item in group_names):
            failures.append(f"role fixture case {name} group_names must be a list of strings")
            continue

        host_updates = raw_case.get("host_vars", {})
        if not isinstance(host_updates, dict):
            failures.append(f"role fixture case {name} host_vars must be a mapping")
            continue
        host_vars = merge_dict(default_host_vars, host_updates)

        remove_fields = raw_case.get("remove_fields", [])
        if not isinstance(remove_fields, list) or not all(isinstance(item, str) for item in remove_fields):
            failures.append(f"role fixture case {name} remove_fields must be a list of strings")
            continue
        for field in remove_fields:
            host_vars.pop(field, None)

        expected_output = raw_case.get("expected_output", "")
        if not isinstance(expected_output, str):
            failures.append(f"role fixture case {name} expected_output must be a string")
            continue

        cases.append(
            RoleCase(
                name=name,
                should_pass=should_pass,
                expected_output=expected_output,
                group_names=tuple(group_names),
                host_vars=host_vars,
                remove_fields=tuple(remove_fields),
            )
        )

    return cases, failures


def is_non_empty_string(value: Any) -> bool:
    return isinstance(value, str) and bool(value.strip())


def is_ipv4_address(value: Any) -> bool:
    if not isinstance(value, str) or not value.strip():
        return False
    octets = value.split(".")
    if len(octets) != 4:
        return False
    for octet in octets:
        if not octet.isdigit():
            return False
        number = int(octet)
        if number < 0 or number > 255:
            return False
    return True


def validate_role_case(case: RoleCase, defaults: dict[str, Any]) -> list[str]:
    host_vars = case.host_vars or {}
    group_names = set(case.group_names)
    inventory_hostname = host_vars.get("inventory_hostname", "fixture-host")
    failures: list[str] = []

    required_host_fields = defaults["host_vars"]["required_host_fields"]
    allowed_architectures = defaults["host_vars"]["allowed_architectures"]
    allowed_storage_types = defaults["host_vars"]["allowed_storage_types"]
    allowed_runtime_roles = defaults["host_vars"]["allowed_runtime_roles"]
    public_exposure_required_fields = defaults["host_vars"]["public_exposure_required_fields"]

    missing_fields = [field for field in required_host_fields if field not in host_vars]
    if missing_fields:
        failures.append(
            f"{inventory_hostname} is missing required inventory fields: {', '.join(missing_fields)}"
        )

    if (
        not is_non_empty_string(host_vars.get("hostname"))
        or inventory_hostname != host_vars.get("hostname")
        or not is_ipv4_address(host_vars.get("ansible_host"))
        or not isinstance(host_vars.get("architecture"), str)
        or host_vars.get("architecture") not in allowed_architectures
        or not is_non_empty_string(host_vars.get("hardware_model"))
        or not isinstance(host_vars.get("storage_type"), str)
        or host_vars.get("storage_type") not in allowed_storage_types
        or not is_non_empty_string(host_vars.get("reliability_notes"))
        or not is_non_empty_string(host_vars.get("placement_notes"))
    ):
        failures.append(
            f"{inventory_hostname} has invalid host identity, management IP, "
            "architecture, hardware, storage, reliability, or placement metadata."
        )

    runtime_roles = host_vars.get("runtime_roles")
    if (
        not isinstance(runtime_roles, list)
        or len(runtime_roles) == 0
        or any(not isinstance(role, str) for role in runtime_roles)
        or any(role not in allowed_runtime_roles for role in runtime_roles)
    ):
        unknown_roles = []
        if isinstance(runtime_roles, list):
            unknown_roles = [role for role in runtime_roles if role not in allowed_runtime_roles]
        failures.append(
            f"{inventory_hostname} must declare at least one supported runtime role. "
            f"Unknown roles: {', '.join(str(role) for role in unknown_roles)}"
        )
    else:
        for role, group in RUNTIME_ROLE_GROUPS.items():
            if (role in runtime_roles) != (group in group_names):
                failures.append(
                    f"{inventory_hostname} runtime group placement mismatch: runtime role "
                    f"{role} maps to expected group {group}, but runtime_roles="
                    f"{', '.join(runtime_roles)} and {group} membership is {group in group_names}."
                )

    architecture = host_vars.get("architecture")
    if isinstance(architecture, str):
        for value, group in ARCHITECTURE_GROUPS.items():
            if (architecture == value) != (group in group_names):
                failures.append(
                    f"{inventory_hostname} architecture group placement mismatch: "
                    f"architecture={architecture} maps to expected group {group} "
                    f"when metadata is {value}, but {group} membership is {group in group_names}."
                )

    storage_type = host_vars.get("storage_type")
    if isinstance(storage_type, str):
        for value, group in STORAGE_GROUPS.items():
            if (storage_type == value) != (group in group_names):
                failures.append(
                    f"{inventory_hostname} storage group placement mismatch: "
                    f"storage_type={storage_type} maps to expected group {group} "
                    f"when metadata is {value}, but {group} membership is {group in group_names}."
                )

    hardware_model = host_vars.get("hardware_model")
    if isinstance(hardware_model, str) and (("zero" in hardware_model.lower()) != ("pi_zero" in group_names)):
        failures.append(
            f"{inventory_hostname} Raspberry Pi Zero group placement mismatch: "
            f"hardware_model={hardware_model} requires pi_zero membership only for "
            f"Zero-class hardware, but pi_zero membership is {'pi_zero' in group_names}."
        )

    public_exposure = host_vars.get("public_exposure")
    if not isinstance(public_exposure, dict):
        failures.append(
            f"{inventory_hostname} must declare public_exposure.exposed as a boolean, "
            "public_exposure.services as a list, and public_exposure.notes as a non-empty string."
        )
    else:
        missing_exposure_fields = [
            field for field in public_exposure_required_fields if field not in public_exposure
        ]
        services = public_exposure.get("services")
        exposed = public_exposure.get("exposed")
        if (
            missing_exposure_fields
            or not isinstance(exposed, bool)
            or not isinstance(services, list)
            or not is_non_empty_string(public_exposure.get("notes"))
            or (exposed and not services)
        ):
            failures.append(
                f"{inventory_hostname} must declare public_exposure.exposed as a boolean, "
                "public_exposure.services as a list, and public_exposure.notes as a non-empty string. "
                "Exposed hosts must declare at least one service."
            )
        elif exposed != ("public_exposed" in group_names):
            failures.append(
                f"{inventory_hostname} public exposure group placement mismatch: "
                f"public_exposure.exposed={exposed} requires matching public_exposed membership, "
                f"but public_exposed membership is {'public_exposed' in group_names}."
            )

        if isinstance(services, list):
            for index, service in enumerate(services, start=1):
                if not isinstance(service, dict):
                    failures.append(
                        f"{inventory_hostname} public exposure service record {index} must be a mapping."
                    )
                    continue
                if (
                    not is_non_empty_string(service.get("name"))
                    or not is_non_empty_string(service.get("protocol"))
                    or service.get("public_port") in ("", None)
                    or not is_non_empty_string(service.get("owner"))
                    or not is_non_empty_string(service.get("internal_target"))
                ):
                    failures.append(
                        f"{inventory_hostname} public exposure service record {index} must include "
                        "non-empty name, protocol, public_port, owner, and internal_target fields."
                    )

    return failures


def run_role_case(case: RoleCase, defaults: dict[str, Any]) -> list[str]:
    failures = validate_role_case(case, defaults)
    output = "\n".join(failures)
    if case.should_pass and failures:
        return [f"{case.name}: expected pass, got failure\n{output}"]
    if not case.should_pass and not failures:
        return [f"{case.name}: expected failure, got pass"]
    if case.expected_output and case.expected_output not in output:
        return [f"{case.name}: expected output fragment not found: {case.expected_output!r}\n{output}"]
    return []


def inventory_for_role_case(case: RoleCase, defaults: dict[str, Any]) -> dict[str, Any]:
    host_vars = dict(case.host_vars or {})
    inventory_hostname = host_vars.pop("inventory_hostname", "fixture-host")
    group_vars = {
        key: host_vars.pop(key)
        for key in (
            "required_host_fields",
            "allowed_architectures",
            "allowed_storage_types",
            "allowed_runtime_roles",
            "public_exposure_required_fields",
        )
        if key in host_vars
    }
    group_vars.setdefault("required_host_fields", defaults["host_vars"]["required_host_fields"])
    group_vars.setdefault("allowed_architectures", defaults["host_vars"]["allowed_architectures"])
    group_vars.setdefault("allowed_storage_types", defaults["host_vars"]["allowed_storage_types"])
    group_vars.setdefault("allowed_runtime_roles", defaults["host_vars"]["allowed_runtime_roles"])
    group_vars.setdefault(
        "public_exposure_required_fields",
        defaults["host_vars"]["public_exposure_required_fields"],
    )

    children = {
        group_name: {"hosts": {inventory_hostname: {}}}
        for group_name in case.group_names
    }
    return {
        "all": {
            "vars": group_vars,
            "hosts": {inventory_hostname: host_vars},
            "children": children,
        }
    }


def run_ansible_role_case(case: RoleCase, defaults: dict[str, Any], ansible_playbook: str) -> list[str]:
    with tempfile.TemporaryDirectory(prefix=f"inventory-assertions-{case.name}-") as tmpdir:
        tmp_path = Path(tmpdir)
        inventory_path = tmp_path / "hosts.yml"
        playbook_path = tmp_path / "assert.yml"

        inventory_path.write_text(
            yaml.safe_dump(inventory_for_role_case(case, defaults), sort_keys=False),
            encoding="utf-8",
        )
        playbook_path.write_text(
            "\n".join(
                [
                    "---",
                    "- name: Inventory assertion fixture",
                    "  hosts: all",
                    "  gather_facts: false",
                    "  connection: local",
                    "  roles:",
                    "    - role: inventory_assertions",
                    "",
                ]
            ),
            encoding="utf-8",
        )

        result = subprocess.run(
            [ansible_playbook, "-i", str(inventory_path), str(playbook_path)],
            cwd=ROOT,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            check=False,
        )

    output = result.stdout + result.stderr
    if case.should_pass and result.returncode != 0:
        return [f"{case.name}: ansible role expected pass, got exit {result.returncode}\n{output}"]
    if not case.should_pass and result.returncode == 0:
        return [f"{case.name}: ansible role expected failure, got pass\n{output}"]
    if case.expected_output and case.expected_output not in output:
        return [
            f"{case.name}: ansible role expected output fragment not found: "
            f"{case.expected_output!r}\n{output}"
        ]
    return []


def main() -> int:
    failures: list[str] = []
    for case in CASES:
        case_failures = run_case(case)
        if case_failures:
            failures.extend(case_failures)
            print(f"FAIL inventory assertion fixture: {case.name}", file=sys.stderr)
        else:
            print(f"PASS inventory assertion fixture: {case.name}")

    role_manifest, role_load_failures = load_role_cases()
    failures.extend(role_load_failures)
    if not role_load_failures:
        defaults = yaml.safe_load(ROLE_FIXTURES.read_text(encoding="utf-8"))["defaults"]
        for case in role_manifest:
            case_failures = run_role_case(case, defaults)
            if case_failures:
                failures.extend(case_failures)
                print(f"FAIL inventory assertion role fixture: {case.name}", file=sys.stderr)
            else:
                print(f"PASS inventory assertion role fixture: {case.name}")

        ansible_playbook = shutil.which("ansible-playbook")
        if ansible_playbook is None:
            print("SKIP inventory assertion Ansible execution fixtures: ansible-playbook is not installed")
        else:
            for case in role_manifest:
                ansible_failures = run_ansible_role_case(case, defaults, ansible_playbook)
                if ansible_failures:
                    failures.extend(ansible_failures)
                    print(
                        f"FAIL inventory assertion Ansible fixture: {case.name}",
                        file=sys.stderr,
                    )
                else:
                    print(f"PASS inventory assertion Ansible fixture: {case.name}")

    if failures:
        print("Inventory assertion contract tests failed:", file=sys.stderr)
        for failure in failures:
            print(f"- {failure}", file=sys.stderr)
        return 1

    print("Inventory assertion contract tests passed.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
